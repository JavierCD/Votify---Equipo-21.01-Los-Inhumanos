@inherits LayoutComponentBase
@inject Votify.Web.Services.UserSession Session
@inject NavigationManager Navigation

<RadzenComponents/>

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 d-flex justify-content-end align-items-center gap-3">

            @if (Session.Usuario != null)
            {
                @* AÑADIMOS position-relative AL CONTENEDOR PADRE *@
                <div class="user-menu position-relative">
                    @* AÑADIMOS cursor: pointer AL MONIGOTE *@
                    <img src="images/monigotevotify.png" class="rounded-circle border" style="width:40px; height:40px; cursor: pointer;" @onclick="ToggleMenu" title="Abrir menú de usuario" />

                    @if (mostrarMenu)
                    {
                        <div class="dropdown-menu show position-absolute shadow p-0" style="right: 0; top: 45px; z-index: 1000; min-width: 220px; border-radius: 8px; overflow: hidden;">

                            @* CABECERA DEL MENÚ (Email) *@
                            <div class="bg-light px-3 py-2 border-bottom text-center">
                                <small class="text-muted fw-bold d-block text-truncate">@Session.Usuario.Email</small>
                            </div>

                            @* ZONA DE BOTONES *@
                            <div class="p-2">
                                @if (Session.Usuario is Votify.Core.Models.Participante p)
                                {
                                    <a class="btn btn-light w-100 text-start mb-2 d-flex align-items-center" href="/ficha-participante/@p.Id">
                                        <RadzenIcon Icon="manage_accounts" class="me-2" Style="font-size: 18px;" /> Mi Perfil
                                    </a>
                                }

                                <button class="btn btn-outline-danger w-100 text-start d-flex align-items-center" @onclick="Logout">
                                    <RadzenIcon Icon="logout" class="me-2" Style="font-size: 18px;" /> Cerrar sesión
                                </button>
                            </div>

                        </div>
                    }
                </div>
            }
            else
            {
                <a class="btn btn-primary" href="/login">Iniciar sesión</a>
                <a class="btn btn-outline-primary" href="/register">Crear cuenta</a>
            }

            

        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private bool mostrarMenu = false;

    void ToggleMenu()
    {
        mostrarMenu = !mostrarMenu;
    }

    void Logout()
    {
        Session.Usuario = null;
        Navigation.NavigateTo("/");
    }
}
