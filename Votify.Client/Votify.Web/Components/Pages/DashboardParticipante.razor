@page "/dashboard-participante/{Id:int}"
@rendermode InteractiveServer

@using Votify.Core.Models
@using Votify.Core.Interfaces

@inject IParticipanteService ParticipanteService
@inject NavigationManager NavManager

<PageTitle>Mi Panel - Votify</PageTitle>

@if (cargando)
{
    <div class="container rz-mt-4 rz-text-align-center">
        <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
        <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-mt-4">Cargando tus participaciones...</RadzenText>
    </div>
}
else if (participante == null)
{
    <div class="container rz-mt-4">
        <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat">
            No se ha encontrado el participante.
        </RadzenAlert>
    </div>
}
else
{
    <div class="container rz-mt-4 rz-mb-5">

        @* --- CABECERA SUPERIOR LIMPIA --- *@
        <RadzenCard class="rz-mb-4 rz-shadow-2" Style="border-left: 4px solid var(--rz-primary);">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                <div>
                    <RadzenText TextStyle="TextStyle.H4" class="rz-m-0 fw-bold">Hola, @participante.Name 👋</RadzenText>
                    <RadzenText TextStyle="TextStyle.Body1" class="text-muted rz-m-0">@participante.Email</RadzenText>
                </div>
                <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem">
                    <RadzenButton Icon="refresh" Text="Actualizar" ButtonStyle="ButtonStyle.Light" Click="CargarDatos" />
                    @* Aquí tienes tu acceso directo al perfil que pedías *@
                    <RadzenButton Icon="manage_accounts" Text="Mi Perfil" ButtonStyle="ButtonStyle.Primary" Click="@(() => NavManager.NavigateTo($"/ficha-participante/{participante.Id}"))" />
                </RadzenStack>
            </RadzenStack>
        </RadzenCard>

        <RadzenText TextStyle="TextStyle.H5" class="rz-mb-4 fw-bold text-secondary">Tus Participaciones Activas</RadzenText>

        @if (participante.Proyectos == null || !participante.Proyectos.Any())
        {
            <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat" class="rz-mt-4">
                Aún no tienes proyectos registrados en ningún evento. ¡Anímate a participar!
            </RadzenAlert>
        }
        else
        {
            @* --- BUCLE: CREAMOS UN ESPACIO GIGANTE POR CADA PROYECTO/EVENTO --- *@
            @foreach (var proyecto in participante.Proyectos)
            {
                <RadzenCard class="rz-mb-5 rz-shadow-3 p-4" Style="border-top: 4px solid var(--rz-info);">

                    @* Título del Proyecto *@
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" class="border-bottom pb-3 rz-mb-3">
                        <div>
                            <RadzenText TextStyle="TextStyle.H5" class="rz-m-0 fw-bold">@proyecto.Name</RadzenText>
                            <RadzenText TextStyle="TextStyle.Caption" class="text-muted">
                                <RadzenIcon Icon="event" Style="font-size: 14px; vertical-align: text-bottom;" /> Inscrito el @proyecto.FechaRegistro.ToString("dd/MM/yyyy")
                            </RadzenText>
                        </div>
                        <RadzenBadge BadgeStyle="BadgeStyle.Success" Text="Votación Abierta" IsPill="true" class="px-3 py-2" />
                    </RadzenStack>

                    <RadzenRow Gap="2rem">
                        @* COLUMNA IZQUIERDA: ACCIONES Y MÉTRICAS *@
                        <RadzenColumn Size="12" SizeLG="4">

                            <div class="bg-light p-3 rounded rz-mb-3 text-center border">
                                <RadzenText TextStyle="TextStyle.Subtitle2" class="text-muted rz-mb-1">Total Puntos / Votos</RadzenText>
                                <RadzenText TextStyle="TextStyle.H2" class="fw-bold rz-color-info rz-m-0">
                                    @(proyecto.Votos?.Sum(v => v.PuntuacionBase) ?? 0)
                                </RadzenText>
                            </div>

                            <RadzenStack Orientation="Orientation.Vertical" Gap="0.5rem">
                                <RadzenButton Text="Editar Participación" Icon="edit_note" ButtonStyle="ButtonStyle.Secondary" Variant="Variant.Outlined" class="w-100" />
                                <RadzenButton Text="Ver Comentarios" Icon="forum" ButtonStyle="ButtonStyle.Warning" class="w-100" />
                            </RadzenStack>

                        </RadzenColumn>

                        @* COLUMNA DERECHA: SU PROPIA GRÁFICA EXCLUSIVA *@
                        <RadzenColumn Size="12" SizeLG="8">
                            <RadzenText TextStyle="TextStyle.Subtitle2" class="text-muted rz-mb-2">Evolución de Votos</RadzenText>

                            @if (proyecto.Votos != null && proyecto.Votos.Any())
                            {
                                @* Generamos los datos reales del gráfico sobre la marcha para este proyecto específico *@
                                var datosGraficoProyecto = proyecto.Votos
                                .GroupBy(v => v.Fecha.ToString("dd MMM"))
                                .Select(g => new { Fecha = g.Key, Puntos = g.Sum(v => v.PuntuacionBase) })
                                .ToList();

                                <RadzenChart>
                                    <RadzenColumnSeries Data="@datosGraficoProyecto" CategoryProperty="Fecha" Title="Votos/Puntos recibidos" ValueProperty="Puntos">
                                        <RadzenSeriesDataLabels Visible="true" />
                                    </RadzenColumnSeries>
                                    <RadzenColumnOptions Radius="4" />
                                    <RadzenLegend Visible="false" />
                                    <RadzenValueAxis>
                                        <RadzenGridLines Visible="true" />
                                    </RadzenValueAxis>
                                </RadzenChart>
                            }
                            else
                            {
                                <div class="d-flex flex-column align-items-center justify-content-center bg-light rounded border border-dashed" style="height: 200px;">
                                    <RadzenIcon Icon="show_chart" Style="font-size: 2.5rem; opacity: 0.3;" />
                                    <span class="text-muted mt-2">Aún no hay votos para analizar</span>
                                </div>
                            }
                        </RadzenColumn>
                    </RadzenRow>
                </RadzenCard>
            }
        }
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Participante? participante;
    private bool cargando = true;

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        cargando = true;

        // El repositorio de Entity Framework traerá al participante, sus proyectos y los votos de cada proyecto
        participante = await ParticipanteService.ObtenerDashboardAsync(Id);

        cargando = false;
    }
}