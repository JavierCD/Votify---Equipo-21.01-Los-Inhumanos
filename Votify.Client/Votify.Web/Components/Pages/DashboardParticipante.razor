@page "/dashboard-participante/{Id:int}"
@rendermode InteractiveServer

@using Votify.Core.Models
@using Votify.Core.Interfaces
@using Votify.Services.Interfaces

@inject IParticipanteService ParticipanteService
@inject NavigationManager NavManager

<PageTitle>Mi Panel - Votify</PageTitle>

@if (cargando)
{
    <div class="container rz-mt-4 rz-text-align-center">
        <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
        <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-mt-4">Cargando tus participaciones...</RadzenText>
    </div>
}
else if (participante == null)
{
    <div class="container rz-mt-4">
        <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat">
            No se ha podido cargar la información de tu perfil en este momento.
        </RadzenAlert>
    </div>
}
else
{
    <div class="container rz-mt-4 rz-mb-5">

        @* --- CABECERA SUPERIOR --- *@
        <RadzenCard class="rz-mb-4 rz-shadow-2" Style="border-left: 4px solid var(--rz-primary);">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                <div>
                    <RadzenText TextStyle="TextStyle.H4" class="rz-m-0 fw-bold">Hola, @participante.Name 👋</RadzenText>
                    <RadzenText TextStyle="TextStyle.Body1" class="text-muted rz-m-0">@participante.Email</RadzenText>
                </div>
                <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem">
                    <RadzenButton Icon="refresh" Text="Actualizar Panel" ButtonStyle="ButtonStyle.Light" Click="CargarDatos" />
                    <RadzenButton Icon="manage_accounts" Text="Mi Perfil" ButtonStyle="ButtonStyle.Primary" Click="@(() => NavManager.NavigateTo($"/ficha-participante/{participante.Id}"))" />
                </RadzenStack>
            </RadzenStack>
        </RadzenCard>

        <RadzenText TextStyle="TextStyle.H5" class="rz-mb-4 fw-bold text-secondary">Tus Participaciones Activas</RadzenText>

        @* --- ESTADO VACÍO (SIN PROYECTOS) --- *@
        @if (participante.Proyectos?.Any() != true)
        {
            <div class="text-center rz-mt-5 rz-mb-5 p-5 bg-light rounded border border-dashed">
                <RadzenIcon Icon="folder_open" Style="font-size: 4rem; color: var(--rz-text-disabled);" class="rz-mb-3" />
                <RadzenText TextStyle="TextStyle.H5" class="fw-bold">Aún no tienes participaciones activas</RadzenText>
                <RadzenText TextStyle="TextStyle.Body1" class="text-muted rz-mb-4">Para empezar a competir y recibir votos, debes inscribir un proyecto en alguno de nuestros eventos disponibles.</RadzenText>
                <RadzenButton Text="Explorar Eventos para Inscribirme" Icon="travel_explore" ButtonStyle="ButtonStyle.Secondary" Click="@(() => NavManager.NavigateTo("/"))" />
            </div>
        }
        else
        {
            @* --- LISTADO DE PROYECTOS --- *@
            @foreach (var proyecto in participante.Proyectos)
            {
                <RadzenCard class="rz-mb-5 rz-shadow-3 p-4" Style="border-top: 4px solid var(--rz-info);">

                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" class="border-bottom pb-3 rz-mb-3">
                        <div>
                            <RadzenText TextStyle="TextStyle.H5" class="rz-m-0 fw-bold">@proyecto.Name</RadzenText>
                            <RadzenText TextStyle="TextStyle.Caption" class="text-muted">
                                <RadzenIcon Icon="event" Style="font-size: 14px; vertical-align: text-bottom;" /> Inscrito el @proyecto.FechaRegistro.ToString("dd/MM/yyyy")
                            </RadzenText>
                        </div>
                        <RadzenBadge BadgeStyle="BadgeStyle.Success" Text="Votación Activa" IsPill="true" class="px-3 py-2" />
                    </RadzenStack>

                    <RadzenRow Gap="2rem">
                        @* MÉTRICAS Y COMENTARIOS *@
                        <RadzenColumn Size="12" SizeLG="4">
                            <div class="bg-light p-3 rounded rz-mb-3 text-center border">
                                <RadzenText TextStyle="TextStyle.Subtitle2" class="text-muted rz-mb-1">Total Puntos / Votos</RadzenText>
                                <RadzenText TextStyle="TextStyle.H2" class="fw-bold rz-color-info rz-m-0">
                                    @(proyecto.Votos?.Sum(v => v.PuntuacionBase) ?? 0)
                                </RadzenText>
                            </div>

                            <RadzenStack Orientation="Orientation.Vertical" Gap="0.5rem">
                                <RadzenButton Text="Editar Participación" Icon="edit_note" ButtonStyle="ButtonStyle.Secondary" Variant="Variant.Outlined" class="w-100" />
                                <RadzenButton Text="Ver Comentarios del Jurado"
                                              Icon="forum"
                                              ButtonStyle="ButtonStyle.Warning"
                                              class="w-100"
                                              Click="@(() => proyectoComentariosAbierto = proyectoComentariosAbierto == proyecto.Id ? 0 : proyecto.Id)" />

                                @if (proyectoComentariosAbierto == proyecto.Id)
                                {
                                    <div class="mt-3">
                                        @if (proyecto.Votos?.Any(v => !string.IsNullOrEmpty(v.Comentario)) != true)
                                        {
                                            <div class="alert alert-info py-2">Aún no hay comentarios del jurado.</div>
                                        }
                                        else
                                        {
                                            @foreach (var voto in proyecto.Votos.Where(v => !string.IsNullOrEmpty(v.Comentario)))
                                            {
                                                <div class="card mb-2 shadow-sm border-0 bg-light">
                                                    <div class="card-body p-3">
                                                        <p class="text-muted small mb-1">🧑‍⚖️ Juez — @voto.Fecha.ToString("dd/MM/yyyy")</p>
                                                        <p class="mb-0" style="font-size: 0.95rem;">@voto.Comentario</p>
                                                    </div>
                                                </div>
                                            }
                                        }
                                    </div>
                                }
                            </RadzenStack>
                        </RadzenColumn>

                        @* GRÁFICA DE VOTOS *@
                        <RadzenColumn Size="12" SizeLG="8">
                            <RadzenText TextStyle="TextStyle.Subtitle2" class="text-muted rz-mb-2">Evolución de Votos</RadzenText>

                            @if (proyecto.Votos?.Any() == true)
                            {
                                var datosGraficoProyecto = proyecto.Votos
                                .GroupBy(v => v.Fecha.ToString("dd MMM"))
                                .Select(g => new { Fecha = g.Key, Puntos = g.Sum(v => v.PuntuacionBase) })
                                .ToList();

                                <RadzenChart>
                                    <RadzenColumnSeries Data="@datosGraficoProyecto" CategoryProperty="Fecha" Title="Puntos" ValueProperty="Puntos">
                                        <RadzenSeriesDataLabels Visible="true" />
                                    </RadzenColumnSeries>
                                    <RadzenColumnOptions Radius="4" />
                                    <RadzenLegend Visible="false" />
                                    <RadzenValueAxis>
                                        <RadzenGridLines Visible="true" />
                                    </RadzenValueAxis>
                                </RadzenChart>
                            }
                            else
                            {
                                <div class="d-flex flex-column align-items-center justify-content-center bg-light rounded border border-dashed" style="height: 200px;">
                                    <RadzenIcon Icon="show_chart" Style="font-size: 2.5rem; opacity: 0.3;" />
                                    <span class="text-muted mt-2">Aún no hay votos registrados</span>
                                </div>
                            }
                        </RadzenColumn>
                    </RadzenRow>

                    @* --- RESULTADOS DE EVENTOS CERRADOS --- *@
                    <RadzenText TextStyle="TextStyle.H5" class="rz-mt-5 rz-mb-3 fw-bold border-bottom pb-2">
                        <RadzenIcon Icon="emoji_events" class="rz-mr-1" Style="color: gold;" /> Resultados Oficiales
                    </RadzenText>

                    @{
                        // LINQ potente y seguro para buscar si alguna votación de este proyecto ya ha publicado resultados
                        var categoriasCerradas = proyecto.Categorias?
                        .Where(c => c.Votacion?.ResultadosPublicados == true)
                        .ToList() ?? new List<Categoria>();
                    }

                    @if (!categoriasCerradas.Any())
                    {
                        <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat" Size="AlertSize.Small">
                            Aún no se han publicado los resultados finales de las categorías donde compites.
                        </RadzenAlert>
                    }
                    else
                    {
                        <RadzenRow Gap="1.5rem">
                            @foreach (var categoria in categoriasCerradas)
                            {
                                var ranking = categoria.Votacion!.Votos
                                .GroupBy(v => v.Proyecto)
                                .Select(g => new { Proyecto = g.Key, Votos = g.Count() })
                                .OrderByDescending(x => x.Votos)
                                .ToList();

                                var miPosicion = ranking.FindIndex(r => r.Proyecto?.Id == proyecto.Id) + 1;

                                <RadzenColumn Size="12" SizeMD="6">
                                    <div class="p-3 bg-light rounded border">
                                        <h6 class="fw-bold mb-3 text-center text-uppercase" style="font-size: 0.85rem; letter-spacing: 1px;">Top 3 - @categoria.Name</h6>
                                        <ul class="list-group list-group-flush mb-3 shadow-sm rounded">
                                            @for (int i = 0; i < Math.Min(3, ranking.Count); i++)
                                            {
                                                var pos = ranking[i];
                                                bool esMio = pos.Proyecto?.Id == proyecto.Id;

                                                <li class="list-group-item d-flex justify-content-between align-items-center @(esMio ? "bg-warning bg-opacity-25 fw-bold" : "")">
                                                    <span>
                                                        <strong class="me-2">@(i + 1)º</strong> @(pos.Proyecto?.Name ?? "Anónimo")
                                                    </span>
                                                    <span class="badge bg-primary rounded-pill">@pos.Votos pts</span>
                                                </li>
                                            }
                                        </ul>
                                        <div class="d-flex justify-content-between align-items-center">
                                            <span>Tu posición: <strong class="fs-5 ms-1">@(miPosicion > 0 ? miPosicion + "º" : "-")</strong></span>
                                            <RadzenButton Text="Certificado" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Secondary" Icon="download" />
                                        </div>
                                    </div>
                                </RadzenColumn>
                            }
                        </RadzenRow>
                    }
                </RadzenCard>
            }
        }
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private int proyectoComentariosAbierto = 0;
    private Participante? participante;
    private bool cargando = true;

    protected override async Task OnParametersSetAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        try
        {
            cargando = true;
            participante = await ParticipanteService.ObtenerDashboardAsync(Id);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar el dashboard: {ex.Message}");
        }
        finally
        {
            cargando = false;
        }
    }
}