@page "/ficha-participante/{Id:int}"
@rendermode InteractiveServer

@using Votify.Core.Models
@using Votify.Core.Interfaces

@inject IParticipanteService ParticipanteService
@* 1. Inyectamos el NavManager para poder hacer el botón de Volver *@
@inject NavigationManager NavManager

<PageTitle>Ficha de Participante - Votify</PageTitle>

@if (cargando)
{
    <div class="container rz-mt-4 rz-text-align-center">
        <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
        <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-mt-4">Buscando en la base de datos...</RadzenText>
    </div>
}
else if (participante == null)
{
    <div class="container rz-mt-4">
        <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat">
            No se ha encontrado ningún participante con el ID @Id.
        </RadzenAlert>
        <RadzenButton Text="Volver a la lista" Icon="arrow_back" ButtonStyle="ButtonStyle.Light" class="rz-mt-3" Click="@Volver" />
    </div>
}
else
{
    <div class="container rz-mt-4">
        @* Botón para volver atrás *@
        <RadzenButton Text="Volver a la lista" Icon="arrow_back" ButtonStyle="ButtonStyle.Light" Variant="Variant.Text" class="rz-mb-2" Click="@Volver" />

        <RadzenText TextStyle="TextStyle.H3">Ficha de Participante</RadzenText>

        <RadzenCard class="rz-mt-2 rz-shadow-3" Style="max-width: 600px;">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem">
                <RadzenIcon Icon="account_circle" Style="font-size: 4rem; color: var(--rz-primary);" />
                
                <RadzenStack Gap="0">
                    <RadzenText TextStyle="TextStyle.H5" class="rz-mb-0">@participante.Name</RadzenText>
                    <RadzenText TextStyle="TextStyle.Body2" class="rz-color-primary-light">@participante.Email</RadzenText>
                    
                    <div class="rz-mt-2">
                        <RadzenBadge BadgeStyle="ObtenerColorEstado(participante.Estado)" Text="@participante.Estado" IsPill="true" />
                        
                        @if(participante.Visible)
                        {
                            <RadzenBadge BadgeStyle="BadgeStyle.Info" Text="Visible" IsPill="true" class="rz-ml-2" />
                        }
                        else
                        {
                            <RadzenBadge BadgeStyle="BadgeStyle.Light" Text="Oculto" IsPill="true" class="rz-ml-2" />
                        }
                    </div>
                </RadzenStack>
            </RadzenStack>

            <RadzenDivider class="rz-my-4" />

            @* ZONA DE EDICIÓN / VISTA *@
            @if (modoEdicion)
            {
                <RadzenStack Gap="1rem">
                    <div>
                        <RadzenText TextStyle="TextStyle.Subtitle2"><b>Visibilidad del perfil</b></RadzenText>
                        <RadzenSwitch @bind-Value="visibleEdit" />
                        <RadzenText TextStyle="TextStyle.Caption" class="rz-ml-2">
                            @(visibleEdit ? "El perfil es público" : "El perfil está oculto")
                        </RadzenText>
                    </div>

                    <div>
                        <RadzenText TextStyle="TextStyle.Subtitle2"><b>Descripción</b></RadzenText>
                        <RadzenTextArea @bind-Value="descripcionEdit" class="w-100" Rows="4" Placeholder="Escribe una descripción..." />
                    </div>

                    <RadzenStack Orientation="Orientation.Horizontal" class="rz-mt-2" Gap="1rem">
                        <RadzenButton Text="Guardar Cambios" ButtonStyle="ButtonStyle.Primary" Icon="save" Click="@GuardarEdicion" />
                        <RadzenButton Text="Cancelar" ButtonStyle="ButtonStyle.Light" Icon="cancel" Click="@CancelarEdicion" />
                    </RadzenStack>
                </RadzenStack>
            }
            else
            {
                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center">
                    <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-m-0"><b>Descripción</b></RadzenText>
                    <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Text="Editar Ficha" Click="@ActivarEdicion" />
                </RadzenStack>

                <RadzenText TextStyle="TextStyle.Body1" class="rz-mt-2">
                    @(string.IsNullOrWhiteSpace(participante.Descripcion) ? "El participante no ha proporcionado una descripción todavía." : participante.Descripcion)
                </RadzenText>
            }

            <RadzenDivider class="rz-my-4" />

            @* BOTONES DE ESTADO (Solo los vemos si no estamos editando) *@
            @if (!modoEdicion)
            {
                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="1rem">
                    @if (participante.Estado != "Rechazado")
                    {
                        <RadzenButton Text="Rechazar" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Outlined" Icon="cancel" Click="@(() => CambiarEstado("Rechazado"))" />
                    }
                    @if (participante.Estado != "Aprobado")
                    {
                        <RadzenButton Text="Aprobar" ButtonStyle="ButtonStyle.Success" Icon="check_circle" Click="@(() => CambiarEstado("Aprobado"))" />
                    }
                </RadzenStack>
            }
        </RadzenCard>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Participante? participante;
    private bool cargando = true;

    // Variables para el modo edición
    private bool modoEdicion = false;
    private string? descripcionEdit;
    private bool visibleEdit;

    protected override async Task OnInitializedAsync()
    {
        participante = await ParticipanteService.ObtenerPorIdAsync(Id);
        cargando = false;
    }

    // --- NAVEGACIÓN ---
    private void Volver()
    {
        NavManager.NavigateTo("/participantes");
    }

    // --- MODO EDICIÓN ---
    private void ActivarEdicion()
    {
        // Copiamos los datos actuales a las variables temporales
        descripcionEdit = participante!.Descripcion;
        visibleEdit = participante.Visible;
        modoEdicion = true;
    }

    private void CancelarEdicion()
    {
        modoEdicion = false;
    }

    private async Task GuardarEdicion()
    {
        try
        {
            // 1. Si ha cambiado la visibilidad, llamamos al servicio
            if (participante!.Visible != visibleEdit)
            {
                await ParticipanteService.CambiarVisibilidadAsync(Id, visibleEdit);
                participante.CambiarVisibilidad(visibleEdit); // Actualizamos la vista local
            }

            // 2. Si ha cambiado la descripción, llamamos al servicio
            if (participante.Descripcion != descripcionEdit)
            {
                // Usamos la regla de dominio que creaste
                participante.ActualizarFicha(descripcionEdit); 
                await ParticipanteService.ActualizarFichaAsync(participante);
            }

            // Salimos del modo edición
            modoEdicion = false;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al guardar: {ex.Message}");
        }
    }

    // --- ESTADO ---
    private async Task CambiarEstado(string nuevoEstado)
    {
        try
        {
            await ParticipanteService.CambiarEstadoAsync(Id, nuevoEstado);
            participante!.EvaluarEstado(nuevoEstado); 
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cambiar estado: {ex.Message}");
        }
    }

    private BadgeStyle ObtenerColorEstado(string estado)
    {
        return estado switch
        {
            "Aprobado" => BadgeStyle.Success,
            "Rechazado" => BadgeStyle.Danger,
            _ => BadgeStyle.Warning
        };
    }

    private string ObtenerNombreEvento(Proyecto proyecto)
    {
        // Navegamos del Proyecto -> a su primera Categoría -> a su Evento
        // (El ? nos protege de errores si la base de datos aún no ha cargado las relaciones)
        var evento = proyecto.Categorias?.FirstOrDefault()?.Evento;
        return evento?.Name ?? "Evento no especificado";
    }

    private string ObtenerModalidadEvento(Proyecto proyecto)
    {
        var evento = proyecto.Categorias?.FirstOrDefault()?.Evento;
        return evento != null ? evento.Modalidad() : "Por definir";
    }

}