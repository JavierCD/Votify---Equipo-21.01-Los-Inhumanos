@page "/evaluacion-proyecto/{ProyectoId:int}"
@rendermode InteractiveServer

@using Votify.Core.Models
@using Votify.Core.Interfaces
@using Votify.Services.Interfaces
@using Votify.Services.Models

@inject IVotoExpertoServices VotoExpertoService
@inject IGenericRepository<Proyecto> ProyectoRepo
@inject NavigationManager NavManager

<PageTitle>Evaluación de mi proyecto - Votify</PageTitle>

<div class="container rz-mt-4 rz-mb-5">

    @* --- CABECERA --- *@
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" class="rz-mb-4">
        <RadzenText TextStyle="TextStyle.H4" class="fw-bold rz-m-0">Evaluación de mi proyecto</RadzenText>
        <RadzenButton Icon="arrow_back" Text="Volver al Panel" ButtonStyle="ButtonStyle.Light"
                      Click="@(() => NavManager.NavigateTo($"/dashboard-participante/{participanteId}"))" />
    </RadzenStack>

    @if (cargando)
    {
        <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
        <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-mt-4 rz-text-align-center">Cargando datos del proyecto...</RadzenText>
    }
    else if (proyecto == null)
    {
        <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat">
            No se encontró el proyecto o no tienes acceso a esta información.
        </RadzenAlert>
    }
    else
    {
        <RadzenCard class="rz-shadow-2 p-4">

            <RadzenText TextStyle="TextStyle.H5" class="fw-bold rz-mb-3">@proyecto.Name</RadzenText>

            @if (!criteriosDelProyecto.Any())
            {
                <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat">
                    No hay criterios de evaluación configurados para este proyecto.
                </RadzenAlert>
            }
            else
            {
                @* --- SELECTOR DE CRITERIO --- *@
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.End" Gap="1rem" class="rz-mb-4">
                    <div style="flex: 1;">
                        <RadzenText TextStyle="TextStyle.Body2" class="text-muted rz-mb-1">Selecciona un criterio</RadzenText>
                        <RadzenDropDown @bind-Value="criterioSeleccionadoId"
                                        Data="@criteriosDelProyecto"
                                        TextProperty="Name"
                                        ValueProperty="Id"
                                        Placeholder="Selecciona un criterio..."
                                        Style="width: 100%;" />
                    </div>
                    <RadzenButton Text="Buscar" Icon="search" ButtonStyle="ButtonStyle.Primary"
                                  Click="BuscarEvaluaciones"
                                  Disabled="@(criterioSeleccionadoId == 0)" />
                </RadzenStack>

                @* --- CONTENIDO --- *@
                @if (!busquedaRealizada)
                {
                    <div class="text-center p-5 bg-light rounded border border-dashed">
                        <RadzenIcon Icon="rate_review" Style="font-size: 3rem; opacity: 0.3;" />
                        <RadzenText TextStyle="TextStyle.H6" class="text-muted rz-mt-2">
                            Selecciona un criterio para ver tu evaluación
                        </RadzenText>
                    </div>
                }
                else if (cargandoEvaluaciones)
                {
                    <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
                }
                else if (!evaluaciones.Any())
                {
                    <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat">
                        Aún no hay evaluaciones para este criterio.
                    </RadzenAlert>
                }
                else
                {
                    <RadzenDataGrid Data="@evaluaciones" TItem="EvaluacionJuezResponse"
                                    AllowSorting="true"
                                    class="rz-mt-2">
                        <Columns>
                            <RadzenDataGridColumn TItem="EvaluacionJuezResponse" Property="NombreJuez" Title="Juez" Width="200px" />
                            <RadzenDataGridColumn TItem="EvaluacionJuezResponse" Property="Puntuacion" Title="Puntuación" Width="120px" TextAlign="TextAlign.Center">
                                <Template Context="eval">
                                    <RadzenBadge BadgeStyle="BadgeStyle.Info" Text="@eval.Puntuacion.ToString("0.#")" IsPill="true" />
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="EvaluacionJuezResponse" Property="Comentario" Title="Comentario">
                                <Template Context="eval">
                                    @if (string.IsNullOrEmpty(eval.Comentario))
                                    {
                                        <span class="text-muted fst-italic">Sin comentario</span>
                                    }
                                    else
                                    {
                                        @eval.Comentario
                                    }
                                </Template>
                            </RadzenDataGridColumn>
                        </Columns>
                    </RadzenDataGrid>
                }
            }

        </RadzenCard>
    }
</div>

@code {
    [Parameter]
    public int ProyectoId { get; set; }

    private Proyecto? proyecto;
    private List<Criterio> criteriosDelProyecto = new();
    private int criterioSeleccionadoId = 0;
    private List<EvaluacionJuezResponse> evaluaciones = new();

    private bool cargando = true;
    private bool cargandoEvaluaciones = false;
    private bool busquedaRealizada = false;
    private int participanteId = 0;

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            cargando = true;

            proyecto = await ProyectoRepo.GetByIdAsync(ProyectoId);

            if (proyecto != null)
            {
                participanteId = proyecto.ParticipanteId;
                criteriosDelProyecto = (await VotoExpertoService.ObtenerCriteriosPorProyectoAsync(ProyectoId)).ToList();
               
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar proyecto: {ex.Message}");
        }
        finally
        {
            cargando = false;
        }
    }

    private async Task BuscarEvaluaciones()
    {
        try
        {
            cargandoEvaluaciones = true;
            busquedaRealizada = true;

            evaluaciones = await VotoExpertoService.ObtenerEvaluacionesParaParticipanteAsync(ProyectoId, criterioSeleccionadoId);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al buscar evaluaciones: {ex.Message}");
            evaluaciones = new();
        }
        finally
        {
            cargandoEvaluaciones = false;
        }
    }
}