    private async Task OnEstadoCambiado(Categoria categoria, string nuevoEstado)
    {
        if (categoria.Votacion.Estado == nuevoEstado) return;

        if(categoria.Votacion.Estado == "ResultadosPublicados")
        {

            return;
        }

        bool exito = await VotacionService.CambiarEstadoVotacionManualAsync(categoria.Votacion.Id, nuevoEstado);

        if (exito)
        {
            // Actualizamos la entidad en la UI localmente para que se reflejen los cambios sin recargar
            switch (nuevoEstado)
            {
                case "Abierta": await CategoriaService.ForzarApertura(categoria); break;
                case "Cerrada": await CategoriaService.ForzarCierre(categoria); break;
                case "Pausada": await CategoriaService.PausarVotacion(categoria); break;
                case "Programada": await CategoriaService.ForzarProgramada(categoria); break;
            }

            // Actualizamos las fechas del modal de edición en la UI por si se expande
            if (fechasEdicion.ContainsKey(categoria.Id))
            {
                fechasEdicion[categoria.Id].Apertura = categoria.Votacion.FechaApertura.ToLocalTime();
                fechasEdicion[categoria.Id].Cierre = categoria.Votacion.FechaCierre.ToLocalTime();
            }

            NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Estado Actualizado", Detail = $"Votación cambiada a {nuevoEstado}" });
        }
        else
        {
            NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Error", Detail = "No se pudo actualizar el estado en el servidor." });
        }
    }

    private BadgeStyle GetBadgeStyle(string estado)
    {
        return estado switch
        {
            "Programada" => BadgeStyle.Info,
            "Abierta" => BadgeStyle.Success,
            "Pausada" => BadgeStyle.Warning,
            "Cerrada" or "CerradaManual" => BadgeStyle.Danger,
            "ResultadosPublicados" => BadgeStyle.Dark,
            _ => BadgeStyle.Light
        };
    }

    private string GetTipoBadgeStyle(string tipo)
    {
        return tipo switch
        {
            "Popular" => "bg-info text-dark",
            "Experto" => "bg-primary",
            "Sponsor" => "bg-warning text-dark",
            _ => "bg-secondary"
        };
    }
