@page "/eventos/editar/{EventoId:int}"
@rendermode InteractiveServer
@using System.Text
@using Votify.Core.Factories
@using Votify.Services.Models
@using Votify.Core.Interfaces
@using Votify.Core.Models
@using Votify.Services.Interfaces
@inject NavigationManager NavigationManager
@inject IEventoService EventoService
@inject ICategoriaService CategoriaService
@inject IEmailService EmailService
@* NUEVA INYECCIÓN PARA LISTAR JUECES *@
@inject IGenericRepository<Juez> JuezRepository
@inject IAuditoriaService AuditoriaService
@inject IResultadosService ResultadosService

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Gestión del Evento: <span class="text-primary">@(evento?.Name ?? "Cargando...")</span></h2>
        <button class="btn btn-outline-secondary" @onclick='() => NavigationManager.NavigateTo("/")'>Volver al Dashboard</button>
    </div>

    @if (evento == null)
    {
        <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Cargando...</span></div>
    }
    else
    {
        <ul class="nav nav-tabs mb-4">
            <li class="nav-item">
                <a class="nav-link @(tabActivo == "Generales" ? "active fw-bold" : "")" @onclick='() => tabActivo = "Generales"' style="cursor:pointer">
                    <RadzenIcon Icon="edit_note" class="me-1" /> Datos Generales
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(tabActivo == "Categorias" ? "active fw-bold" : "")" @onclick='() => tabActivo = "Categorias"' style="cursor:pointer">
                    <RadzenIcon Icon="category" class="me-1" /> Categorías y Votaciones
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(tabActivo == "Participantes" ? "active fw-bold" : "")" @onclick='() => tabActivo = "Participantes"' style="cursor:pointer">
                    <RadzenIcon Icon="groups" class="me-1" /> Participantes
                </a>
            </li>
            @* NUEVA PESTAÑA DE JURADO *@
            <li class="nav-item">
                <a class="nav-link @(tabActivo == "Jurado" ? "active fw-bold" : "")" @onclick='() => tabActivo = "Jurado"' style="cursor:pointer">
                    <RadzenIcon Icon="gavel" class="me-1" /> Jurado
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(tabActivo == "Auditoria" ? "active fw-bold" : "")" @onclick='() => CambiarTab("Auditoria")' style="cursor:pointer">
                    <RadzenIcon Icon="verified_user" class="me-1" /> Auditoría
                </a>
            </li>
        </ul>

        @* MENSAJES GLOBALES DE ÉXITO Y ERROR *@
        @if (!string.IsNullOrEmpty(mensajeExito))
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <RadzenIcon Icon="check_circle" class="me-1" /> @mensajeExito
                <button type="button" class="btn-close" @onclick="() => mensajeExito = null"></button>
            </div>
        }

        @if (!string.IsNullOrEmpty(mensajeError))
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <RadzenIcon Icon="error" class="me-1" /> @mensajeError
                <button type="button" class="btn-close" @onclick="() => mensajeError = null"></button>
            </div>
        }

        @if (tabActivo == "Generales")
        {
            <div class="card shadow-sm p-4" style="max-width: 600px;">
                <h4 class="mb-4">Información Principal</h4>

                <div class="mb-3">
                    <label class="form-label fw-bold">Nombre del Evento</label>
                    <input type="text" class="form-control" @bind="evento.Name" />
                </div>
                <div class="row mb-3">
                    <div class="col">
                        <label class="form-label fw-bold">Fecha de Inicio</label>
                        <input type="date" class="form-control" @bind="fechaInicioTemp" />
                    </div>
                    <div class="col">
                        <label class="form-label fw-bold">Fecha de Fin</label>
                        <input type="date" class="form-control" @bind="fechaFinTemp" />
                    </div>
                </div>
                <div class="mb-4">
                    <label class="form-label fw-bold">Descripción / Reglas</label>
                    <textarea class="form-control" rows="4" @bind="evento.Description"></textarea>
                </div>
                <button class="btn btn-primary" @onclick="GuardarDatosGenerales">Guardar Cambios</button>
            </div>
        }

        else if (tabActivo == "Categorias")
        {
            <div class="row">
                <div class="col-12">
                    @foreach (var categoria in evento.CategoriasEvento)
                    {
                        <div class="card mb-4 shadow-sm border-start border-primary border-4">
                            <div class="card-header bg-light">
                                <h5 class="mb-0">@categoria.Name</h5>
                            </div>
                            <div class="card-body row">

                                <div class="col-md-5 border-end">
                                    <h6>Estado de la Votación</h6>

                                    @if (categoria.Votacion == null)
                                    {
                                        <p class="text-muted small">Aún no hay votación configurada.</p>
                                        <button class="btn btn-sm btn-outline-primary w-100"
                                                @onclick='() => NavigationManager.NavigateTo($"/voto-popular/{categoria.Id}")'>
                                            Configurar Votación
                                        </button>
                                    }
                                    else if (!categoria.Votacion.EstaCerrada)
                                    {
                                        <div class="alert alert-success p-2 small d-flex justify-content-between align-items-center">
                                            <span><RadzenIcon Icon="how_to_vote" class="me-1" /> En curso</span>
                                            <span class="badge bg-success">@(categoria.Votacion.Votos?.Count ?? 0) votos</span>
                                        </div>

                                        <div class="alert alert-success p-2 small d-flex justify-content-between align-items-center">
                                            <RadzenBadge BadgeStyle="BadgeStyle.Info"
                                                         Text="@($"ID Votación: {categoria.Votacion.Id}")" />
                                        </div>

                                        <button class="btn btn-sm btn-warning w-100 fw-bold shadow-sm"
                                                @onclick="() => CerrarVotacionCategoria(categoria.Id)">
                                            <RadzenIcon Icon="lock" class="me-1" /> Cerrar Votación
                                        </button>
                                    }
                                    else
                                    {
                                        <div class="alert alert-secondary p-2 small mb-2">
                                            <RadzenIcon Icon="lock" class="me-1" /> Votación Cerrada
                                        </div>

                                        <div class="bg-white border rounded p-2 mb-3">
                                            <strong class="small d-block mb-2 border-bottom pb-1">Clasificación Actual:</strong>

                                            @{
                                                var ranking = categoria.Votacion.Votos
                                                .GroupBy(v => v.Proyecto)
                                                .Select(g => new { Proyecto = g.Key, Votos = g.Count() })
                                                .OrderByDescending(x => x.Votos)
                                                .ToList();
                                            }

                                            @if (!ranking.Any())
                                            {
                                                <span class="text-muted small">Nadie votó en esta categoría.</span>
                                            }
                                            else
                                            {
                                                <ul class="list-unstyled mb-0 small">
                                                    @for (int i = 0; i < Math.Min(3, ranking.Count); i++)
                                                    {
                                                        var posicion = ranking[i];
                                                        <li class="mb-1">
                                                            <strong>@(i + 1)º</strong> @(posicion.Proyecto?.Name ?? "Proyecto Eliminado")
                                                            <span class="badge bg-light text-dark float-end">@posicion.Votos pts</span>
                                                        </li>
                                                    }
                                                </ul>
                                            }
                                        </div>

                                        <button class="btn btn-sm w-100 fw-bold shadow-sm @(categoria.Votacion.ResultadosPublicados ? "btn-success disabled" : "btn-primary")"
                                                @onclick="() => CompartirClasificacion(categoria)">

                                            <RadzenIcon Icon="@(categoria.Votacion.ResultadosPublicados ? "check_circle" : "send")" class="me-1" />
                                            @(categoria.Votacion.ResultadosPublicados ? "Clasificación Compartida" : "Compartir Clasificación")
                                        </button>
                                    }
                                </div>

                                <div class="col-md-7 ps-4">
                                    <h6>Premios de la Categoría</h6>
                                    <ul class="list-group mb-3">
                                        @foreach (var premio in categoria.Premios.OrderBy(p => p.Posicion))
                                        {
                                            <li class="list-group-item d-flex justify-content-between align-items-start">
                                                <div>
                                                    <span class="badge bg-warning text-dark me-2">#@premio.Posicion</span>
                                                    <strong>@premio.Name</strong>
                                                    @if (!string.IsNullOrEmpty(premio.Descripcion))
                                                    {
                                                        <div class="text-muted small mt-1">@premio.Descripcion</div>
                                                    }
                                                </div>
                                                <button class="btn btn-sm text-danger border-0"
                                                        @onclick="() => EliminarPremioConcreto(categoria.Id, premio.Id)">
                                                    <RadzenIcon Icon="delete" />
                                                </button>
                                            </li>
                                        }
                                    </ul>

                                    <div class="bg-light p-3 rounded">
                                        <span class="fw-bold small d-block mb-2">Añadir Nuevo Premio</span>
                                        <div class="row g-2">
                                            <div class="col-3">
                                                <input type="number" class="form-control form-control-sm" placeholder="Puesto" @bind="nuevoPremioPuesto" min="1" />
                                            </div>
                                            <div class="col-9">
                                                <input type="text" class="form-control form-control-sm" placeholder="Nombre (Ej: Cheque 500€)" @bind="nuevoPremioNombre" />
                                            </div>
                                            <div class="col-12">
                                                <input type="text" class="form-control form-control-sm" placeholder="Descripción breve (opcional)" @bind="nuevoPremioDesc" />
                                            </div>
                                            <div class="col-12 text-end mt-2">
                                                <button class="btn btn-sm btn-success px-3" @onclick="() => AgregarPremioConcreto(categoria.Id)">Añadir Premio</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        else if (tabActivo == "Participantes")
        {
            <div class="card shadow-sm p-4">
                <h4 class="mb-4">Participantes y Proyectos</h4>

                @foreach (var categoria in evento.CategoriasEvento)
                {
                    <div class="mb-5">
                        <h5 class="text-primary border-bottom pb-2 mb-3">
                            <RadzenIcon Icon="label" class="fs-5 me-1" /> @categoria.Name
                            <span class="badge bg-secondary ms-2 fs-6">@categoria.Proyectos.Count inscritos</span>
                        </h5>

                        @if (!categoria.Proyectos.Any())
                        {
                            <p class="text-muted fst-italic">Aún no hay proyectos inscritos en esta categoría.</p>
                        }
                        else
                        {
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Nombre del Proyecto</th>
                                        <th>Creador</th>
                                        <th>Tipo de Proyecto</th>
                                        <th>Fecha Inscripción</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var proyecto in categoria.Proyectos)
                                    {
                                        <tr>
                                            <td class="fw-bold">@proyecto.Name</td>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <RadzenIcon Icon="person" class="me-1 text-secondary" />
                                                    @(proyecto.Participante?.Name ?? "Desconocido")
                                                </div>
                                            </td>
                                            <td><span class="badge bg-info text-dark">@proyecto.CategoriaEspecialidad()</span></td>
                                            <td>@proyecto.FechaRegistro.ToShortDateString()</td>
                                            <td>
                                                @if (proyecto.Participante != null)
                                                {
                                                    <button class="btn btn-sm btn-outline-info me-1" title="Ver ficha del participante"
                                                            @onclick='() => NavigationManager.NavigateTo($"/ficha-participante/{proyecto.Participante.Id}")'>
                                                        <RadzenIcon Icon="visibility" Style="font-size: 16px;" /> Ver Ficha
                                                    </button>
                                                }
                                                <button class="btn btn-sm btn-outline-danger">Descalificar</button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                }
            </div>
        }

        @* ---------------------------------------------------- *@
        @* NUEVA SECCIÓN COMPLETA DE ASIGNACIÓN DE JURADO       *@
        @* ---------------------------------------------------- *@
        else if (tabActivo == "Jurado")
        {
            <div class="card shadow-sm p-4">
                <h4 class="mb-4"><RadzenIcon Icon="gavel" class="fs-4 me-2 text-primary" /> Gestión del Jurado del Evento</h4>
                <p class="text-muted">Añade expertos que tendrán permiso para votar y evaluar en todas las categorías de este evento.</p>

                <div class="row mt-4">
                    <div class="col-md-6 border-end">
                        <h6 class="fw-bold mb-3">Vincular nuevo experto</h6>
                        <label class="form-label">Seleccionar Juez registrado en Votify:</label>
                        <div class="input-group mb-3">
                            <select class="form-select" @bind="juezSeleccionadoId">
                                <option value="0">-- Elige un juez del sistema --</option>
                                @foreach (var juez in todosLosJueces)
                                {
                                    <option value="@juez.Id">@juez.Name (@juez.Email)</option>
                                }
                            </select>
                            <button class="btn btn-primary" @onclick="AsignarJuez" disabled="@(juezSeleccionadoId == 0)">
                                Añadir al Evento
                            </button>
                        </div>
                    </div>

                    <div class="col-md-6 ps-4">
                        <h6 class="fw-bold mb-3">Jueces actualmente asignados (@(evento.Jurado?.Count ?? 0))</h6>
                        <ul class="list-group">
                            @if (evento.Jurado != null && evento.Jurado.Any())
                            {
                                @foreach (var asignado in evento.Jurado)
                                {
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        <span><RadzenIcon Icon="account_circle" class="me-2 text-secondary" /> @asignado.Name</span>
                                        <div>
                                            <small class="text-muted me-3">@asignado.Email</small>
                                            <button class="btn btn-sm btn-outline-danger border-0"
                                                    title="Quitar juez del evento"
                                                    @onclick="() => QuitarJuez(asignado.Id)">
                                                <RadzenIcon Icon="person_remove" />
                                            </button>
                                        </div>
                                    </li>
                                }
                            }
                            else
                            {
                                <li class="list-group-item text-muted text-center fst-italic">Aún no hay jueces asignados a este evento.</li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        }

        @* NUEVA SECCIÓN COMPLETA DE AUDITORIAS *@

        else if (tabActivo == "Auditoria")
        {
            <div class="card shadow-sm p-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4><RadzenIcon Icon="security" class="me-2 text-success" /> Trazabilidad de Votos</h4>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="CargarAuditoria">
                        <RadzenIcon Icon="refresh" style="vertical-align: middle;" /> Actualizar
                    </button>
                </div>

                @if (cargandoAuditoria)
                {
                    <div class="text-center py-5">
                        <div class="spinner-border text-success" role="status"></div>
                        <p class="mt-2">Verificando integridad de los votos...</p>
                    </div>
                }
                else if (!historialVotos.Any())
                {
                    <div class="alert alert-info">Aún no se han registrado votos en este evento.</div>
                }
                else
                {
                    @* --- TABLA RADZEN CON FILTROS INTEGADOS --- *@
                    <RadzenDataGrid AllowFiltering="true" AllowColumnResize="true" AllowAlternatingRows="false"
                                    FilterMode="FilterMode.Simple" AllowSorting="true" PageSize="10"
                                    AllowPaging="true" PagerHorizontalAlign="HorizontalAlign.Left" ShowPagingSummary="true"
                                    Data="@historialVotos" TItem="AuditoriaVotoResponse" LogicalFilterOperator="LogicalFilterOperator.Or">
                        <Columns>
                            <RadzenDataGridColumn TItem="AuditoriaVotoResponse" Property="FechaEmision" Title="Fecha (UTC)" FormatString="{0:dd/MM/yyyy HH:mm:ss}" Width="180px" />

                            <RadzenDataGridColumn TItem="AuditoriaVotoResponse" Property="ProyectoNombre" Title="Proyecto Votado" />

                            <RadzenDataGridColumn TItem="AuditoriaVotoResponse" Property="TipoVotacion" Title="Tipo de Voto" Width="150px">
                                <Template Context="v">
                                    <span class="badge @(v.TipoVotacion == "EXPERT" ? "bg-primary" : "bg-info text-dark")">
                                        @(v.TipoVotacion == "EXPERT" ? "Jurado" : "Popular")
                                    </span>
                                </Template>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn TItem="AuditoriaVotoResponse" Property="IdentificadorVotante" Title="Identificador del Votante">
                                <Template Context="v">
                                    @if (v.EsAnonimo)
                                    {
                                        <span class="text-muted" title="Voto cifrado y anónimo">
                                            <RadzenIcon Icon="lock" Style="font-size:14px" /> <code>@v.IdentificadorVotante</code>
                                        </span>
                                    }
                                    else
                                    {
                                        <span>
                                            <RadzenIcon Icon="person" Style="font-size:14px" /> @v.IdentificadorVotante
                                        </span>
                                    }
                                </Template>
                            </RadzenDataGridColumn>
                        </Columns>
                    </RadzenDataGrid>
                }
            </div>
        }
    }
</div>

@code {
    [Parameter]
    public int EventoId { get; set; }

    private string tabActivo = "Generales";
    private Evento? evento;

    // Fechas
    private DateTime fechaInicioTemp;
    private DateTime fechaFinTemp;

    // Premios
    private string nuevoPremioNombre = "";
    private string nuevoPremioDesc = "";
    private int nuevoPremioPuesto = 1;

    // Jueces
    private List<Juez> todosLosJueces = new();
    private int juezSeleccionadoId = 0;

    // Alertas
    private string? mensajeExito;
    private string? mensajeError;

    private EditarEventoRequest requestModel = new EditarEventoRequest();
    private AgregarPremioRequest requestPremio = new AgregarPremioRequest();

    // Auditoría
    private List<AuditoriaVotoResponse> historialVotos = new();
    private bool cargandoAuditoria = false;

    protected override async Task OnInitializedAsync()
    {
        await CargarEventoYJueces();
    }

    private async Task CargarEventoYJueces()
    {
        // 1. Cargamos el evento
        evento = await EventoService.ObtenerEventoConDetallesAsync(EventoId);

        // 2. Cargamos TODOS los jueces disponibles en el sistema para el Dropdown
        todosLosJueces = (await JuezRepository.GetAllAsync()).ToList();

        if (evento != null)
        {
            fechaInicioTemp = evento.FechaInicio;
            fechaFinTemp = evento.FechaFin;

            requestModel.Id = evento.Id;
            requestModel.Name = evento.Name;
            requestModel.FechaInicio = evento.FechaInicio;
            requestModel.FechaFin = evento.FechaFin;
            requestModel.Description = evento.Description;
        }
    }

    // --------------------------------------------------------
    // NUEVO MÉTODO PARA ASIGNAR JUEZ
    // --------------------------------------------------------
    private async Task AsignarJuez()
    {
        mensajeError = null;
        mensajeExito = null;

        try
        {
            await EventoService.AsignarJuezAEventoAsync(juezSeleccionadoId, EventoId);

            mensajeExito = "El juez ha sido asignado al evento correctamente.";

            // Recargamos los datos para que el juez aparezca en la lista de la derecha
            await CargarEventoYJueces();

            // Reseteamos el select
            juezSeleccionadoId = 0;
        }
        catch (InvalidOperationException ex)
        {
            mensajeError = ex.Message; // Mostrará si ya está asignado
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al asignar juez: {ex.Message}";
        }
    }

    // --------------------------------------------------------
    // NUEVO MÉTODO PARA QUITAR JUEZ
    // --------------------------------------------------------
    private async Task QuitarJuez(int juezId)
    {
        mensajeError = null;
        mensajeExito = null;

        try
        {
            await EventoService.DesasignarJuezAEventoAsync(juezId, EventoId);

            mensajeExito = "El juez ha sido desvinculado del evento.";

            // Recargamos los datos para que desaparezca de la lista
            await CargarEventoYJueces();
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al quitar juez: {ex.Message}";
        }
    }

    // --- RESTO DE TUS MÉTODOS EXISTENTES SE QUEDAN EXACTAMENTE IGUAL ---

    private void AbrirModalVotacion(int categoriaId) { /* ... */ }

    private async void AgregarPremioConcreto(int categoriaId)
    {
        if (string.IsNullOrWhiteSpace(nuevoPremioNombre)) return;

        var categoria = evento!.CategoriasEvento.First(c => c.Id == categoriaId);

        if (categoria != null)
        {
            requestPremio.categoriaID = categoria.Id;
            requestPremio.nombrePremio = nuevoPremioNombre;
            requestPremio.premioDesc = nuevoPremioDesc;
            requestPremio.puesto = nuevoPremioPuesto;
        }

        await CategoriaService.AgregarPremioAsync(requestPremio);

        nuevoPremioNombre = "";
        nuevoPremioDesc = "";
        nuevoPremioPuesto++;
    }

    private async Task GuardarDatosGenerales()
    {
        mensajeExito = null;
        mensajeError = null;

        try
        {
            if (evento == null) return;
            await EventoService.ActualizarAsync(requestModel);
            mensajeExito = "Los datos generales del evento se han actualizado correctamente.";
        }
        catch (Exception ex) { mensajeError = ex.Message; }
    }

    private async Task EliminarPremioConcreto(int categoriaId, int premioId)
    {
        try
        {
            await CategoriaService.EliminarPremioAsync(categoriaId, premioId);
        }
        catch (Exception ex) { mensajeError = ex.Message; }
    }

    private async Task CerrarVotacionCategoria(int categoriaId)
    {
        try
        {
            await CategoriaService.CerrarVotacionAsync(categoriaId);

        }
        catch (Exception ex) { mensajeError = ex.Message; }
    }

    private async Task CompartirClasificacion(Categoria categoria)
    {
        try
        {
            // La UI solo llama al servicio y recibe la respuesta
            int cantidadEnviados = await ResultadosService.CompartirClasificacionAsync(categoria.Id);

            mensajeExito = $"¡La clasificación se ha enviado por correo a {cantidadEnviados} votantes!";
        }
        catch (InvalidOperationException ex)
        {
            // Manejo específico de reglas de dominio violadas
            mensajeError = ex.Message;
        }
        catch (Exception ex)
        {
            // Manejo general de errores
            mensajeError = $"Error al compartir: {ex.Message}";
        }
    }

    // Auditoría
    private async Task CambiarTab(string nuevoTab)
    {
        tabActivo = nuevoTab;
        if (tabActivo == "Auditoria")
        {
            await CargarAuditoria();
        }
    }

    private async Task CargarAuditoria()
    {
        cargandoAuditoria = true;
        try
        {
            historialVotos = await AuditoriaService.ObtenerHistorialPorEventoAsync(EventoId);
        }
        finally
        {
            cargandoAuditoria = false;
        }
    }
}