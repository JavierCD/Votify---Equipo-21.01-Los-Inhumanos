@page "/eventos"
@using Votify.Core.Models
@using Votify.Core.Interfaces
@using Votify.Services.Implementations
@inject IEventoService EventoService

<PageTitle>Lista de Eventos</PageTitle>

<RadzenText TextStyle="TextStyle.H3" TagName="TagName.H1" Class="rz-mb-6">
    Eventos de Votify
</RadzenText>

@if (eventos == null)
{
    // Un pequeño indicador de carga animado y elegante
    <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
}
else
{
    <RadzenDataGrid Data="@eventos" TItem="Evento" AllowPaging="true" PageSize="10" AllowSorting="true" class="rz-shadow-3">
        <Columns>
            <RadzenDataGridColumn TItem="Evento" Property="Id" Title="ID" Width="80px" TextAlign="TextAlign.Center" />

            <RadzenDataGridColumn TItem="Evento" Property="Name" Title="Nombre del Evento" />

            <RadzenDataGridColumn TItem="Evento" Property="Estado" Title="Estado" Width="150px">
                <Template Context="evento">
                    <RadzenBadge BadgeStyle="GetBadgeStyle(evento.Estado)" Text="@evento.Estado" />
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="Evento" Title="Acciones" Width="120px" TextAlign="TextAlign.Center">
                <Template Context="evento">
                    <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                                  Click="@(() => EditarEvento(evento.Id))" />
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
}

@code {
    private IEnumerable<Evento>? eventos;

    // Se ejecuta al cargar la página
    protected override async Task OnInitializedAsync()
    {
        // Llamamos directamente a nuestro servicio (El Atajo Mágico)
        eventos = await EventoService.ObtenerTodosAsync();
    }

    // Un pequeño método para darle color al estado del evento
    private BadgeStyle GetBadgeStyle(string estado)
    {
        return estado switch
        {
            "Activo" => BadgeStyle.Success,
            "Borrador" => BadgeStyle.Light,
            "Cerrado" => BadgeStyle.Danger,
            _ => BadgeStyle.Info
        };
    }

    private void EditarEvento(int id)
    {
        // Aquí en el futuro navegaremos a la página de edición
        Console.WriteLine($"Editar evento {id}");
    }
}