@page "/ficha-participante/{Id:int}"
@rendermode InteractiveServer

@using Votify.Core.Models
@using Votify.Core.Interfaces

@inject IParticipanteService ParticipanteService
@inject NavigationManager NavManager
@* Inyectamos JSRuntime para poder usar el history.back() del navegador *@
@inject IJSRuntime JSRuntime

<PageTitle>Mi Perfil - Votify</PageTitle>

@if (cargando)
{
    <div class="container rz-mt-5 rz-text-align-center">
        <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
        <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-mt-4">Cargando perfil...</RadzenText>
    </div>
}
else if (participante == null)
{
    <div class="container rz-mt-5">
        <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat">No se encontró el perfil.</RadzenAlert>
    </div>
}
else
{
    <div class="container rz-mt-4 rz-mb-5">

        @* NUEVO BOTÓN DE VOLVER: Más visible y con historial dinámico *@
        <RadzenButton Text="Volver" Icon="arrow_back" ButtonStyle="ButtonStyle.Dark" class="rz-mb-4 rz-shadow-2" Click="VolverAtras" />

        <RadzenRow Gap="2rem">
            @* COLUMNA IZQUIERDA: TARJETA DE IDENTIDAD *@
            <RadzenColumn Size="12" SizeMD="4">
                <RadzenCard class="rz-shadow-3 rz-p-0" Style="overflow: hidden; border-radius: 12px;">

                    @* EL SALVAVIDAS: Si lo dejan en blanco, usamos el azul por defecto *@
                    @{
                        var colorSeguro = string.IsNullOrWhiteSpace(participante.ColorFondo) ? "#479cc8" : participante.ColorFondo;
                    }

                    <div style="height: 120px; background-color: @colorSeguro;"></div>

                    <div class="d-flex flex-column align-items-center rz-p-4" style="margin-top: -60px;">
                        @if (!string.IsNullOrEmpty(participante.UrlFoto))
                        {
                            <img src="@participante.UrlFoto" alt="Foto de perfil" style="width: 120px; height: 120px; border-radius: 50%; border: 4px solid white; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="d-flex align-items-center justify-content-center text-white fw-bold shadow-sm"
                                 style="width: 120px; height: 120px; border-radius: 50%; border: 4px solid white; background-color: @colorSeguro; font-size: 2.5rem;">
                                @ObtenerIniciales(participante.Name)
                            </div>
                        }

                        <RadzenText TextStyle="TextStyle.H5" class="fw-bold rz-mt-3 rz-mb-0 text-center">@participante.Name</RadzenText>
                        <RadzenText TextStyle="TextStyle.Body2" class="text-muted rz-mb-3 text-center">@participante.Email</RadzenText>

                        @if (!modoEdicion)
                        {
                            <RadzenButton Text="Editar Perfil" Icon="edit" ButtonStyle="ButtonStyle.Primary" Variant="Variant.Outlined" class="w-100 rz-mt-2" Click="ActivarEdicion" />
                        }
                        else
                        {
                            <RadzenButton Text="Guardar Cambios" Icon="save" ButtonStyle="ButtonStyle.Success" class="w-100 rz-mt-2" Click="GuardarPerfil" />
                            <RadzenButton Text="Cancelar" Icon="cancel" ButtonStyle="ButtonStyle.Light" class="w-100 rz-mt-2" Click="CancelarEdicion" />
                        }
                    </div>
                </RadzenCard>
            </RadzenColumn>

            @* COLUMNA DERECHA: INFORMACIÓN DETALLADA / FORMULARIO *@
            <RadzenColumn Size="12" SizeMD="8">

                @if (modoEdicion)
                {
                    @* --- MODO EDICIÓN --- *@
                    <RadzenCard class="rz-shadow-2 rz-mb-4" Style="border-top: 4px solid var(--rz-success);">
                        <RadzenText TextStyle="TextStyle.H6" class="fw-bold rz-mb-3 text-success">Editando Perfil</RadzenText>

                        <RadzenStack Orientation="Orientation.Vertical" Gap="1rem">
                            <div>
                                <RadzenText TextStyle="TextStyle.Subtitle2">Nombre Público</RadzenText>
                                <RadzenTextBox @bind-Value="participante.Name" class="w-100" />
                            </div>

                            <div>
                                <RadzenText TextStyle="TextStyle.Subtitle2">Sobre Mí (Biografía)</RadzenText>
                                <RadzenTextArea @bind-Value="participante.Descripcion" class="w-100" Rows="4" />
                            </div>

                            <RadzenRow>
                                <RadzenColumn Size="12" SizeSM="6">
                                    <RadzenText TextStyle="TextStyle.Subtitle2">Estudios / Institución</RadzenText>
                                    <RadzenTextBox @bind-Value="participante.InstitucionEducativa" class="w-100" Placeholder="Ej: Univ. Complutense" />
                                </RadzenColumn>
                                <RadzenColumn Size="12" SizeSM="6">
                                    <RadzenText TextStyle="TextStyle.Subtitle2">Intereses (Separados por coma)</RadzenText>
                                    <RadzenTextBox @bind-Value="participante.Intereses" class="w-100" Placeholder="Ej: IA, C#, Diseño UX" />
                                </RadzenColumn>
                            </RadzenRow>

                            <div>
                                <RadzenText TextStyle="TextStyle.Subtitle2">Color de Fondo (Hexadecimal)</RadzenText>
                                <RadzenColorPicker @bind-Value="participante.ColorFondo" ShowHSV="true" ShowRGBA="false" ShowColors="true" class="w-100" />
                            </div>
                        </RadzenStack>
                    </RadzenCard>
                }
                else
                {
                    @* --- MODO LECTURA (Lo que tenías antes) --- *@
                    <RadzenCard class="rz-shadow-2 rz-mb-4">
                        <RadzenText TextStyle="TextStyle.H6" class="fw-bold rz-mb-3 text-secondary">Sobre Mí</RadzenText>
                        @if (string.IsNullOrWhiteSpace(participante.Descripcion))
                        {
                            <RadzenText TextStyle="TextStyle.Body1" class="text-muted fst-italic">Aún no hay biografía disponible.</RadzenText>
                        }
                        else
                        {
                            <RadzenText TextStyle="TextStyle.Body1">@participante.Descripcion</RadzenText>
                        }
                    </RadzenCard>

                    <RadzenCard class="rz-shadow-2 rz-mb-4">
                        <RadzenRow>
                            <RadzenColumn Size="12" SizeSM="6">
                                <RadzenText TextStyle="TextStyle.Subtitle2" class="text-muted rz-mb-1"><RadzenIcon Icon="school" class="rz-mr-1" Style="font-size: 16px;" /> Estudios / Institución</RadzenText>
                                <RadzenText TextStyle="TextStyle.Body1" class="fw-bold">
                                    @(string.IsNullOrWhiteSpace(participante.InstitucionEducativa) ? "No especificado" : participante.InstitucionEducativa)
                                </RadzenText>
                            </RadzenColumn>
                            <RadzenColumn Size="12" SizeSM="6">
                                <RadzenText TextStyle="TextStyle.Subtitle2" class="text-muted rz-mb-2"><RadzenIcon Icon="local_offer" class="rz-mr-1" Style="font-size: 16px;" /> Áreas de Interés</RadzenText>

                                @if (string.IsNullOrWhiteSpace(participante.Intereses))
                                {
                                    <RadzenText TextStyle="TextStyle.Body2" class="text-muted">Ningún interés añadido.</RadzenText>
                                }
                                else
                                {
                                    <RadzenStack Orientation="Orientation.Horizontal" Wrap="FlexWrap.Wrap" Gap="0.5rem">
                                        @foreach (var interes in participante.Intereses.Split(',', StringSplitOptions.RemoveEmptyEntries))
                                        {
                                            <RadzenBadge BadgeStyle="BadgeStyle.Light" Text="@interes.Trim()" IsPill="true" class="border" />
                                        }
                                    </RadzenStack>
                                }
                            </RadzenColumn>
                        </RadzenRow>
                    </RadzenCard>
                }

                @* Vitrina de Proyectos (Siempre visible) *@
                <RadzenCard class="rz-shadow-2">
                    <RadzenText TextStyle="TextStyle.H6" class="fw-bold rz-mb-3 text-secondary"><RadzenIcon Icon="emoji_events" class="rz-mr-1" /> Vitrina de Proyectos</RadzenText>
                    @if (participante.Proyectos != null && participante.Proyectos.Any())
                    {
                        <div class="row g-3">
                            @foreach (var proyecto in participante.Proyectos)
                            {
                                <div class="col-12 col-md-6">
                                    <div class="p-3 border rounded h-100 bg-light">
                                        <RadzenText TextStyle="TextStyle.Subtitle1" class="fw-bold rz-m-0 rz-color-primary">@proyecto.Name</RadzenText>
                                        <RadzenText TextStyle="TextStyle.Caption" class="text-muted d-block rz-mb-2">Inscrito en @proyecto.FechaRegistro.Year</RadzenText>
                                        <RadzenText TextStyle="TextStyle.Body2" class="text-truncate">
                                            @(string.IsNullOrWhiteSpace(proyecto.Description) ? "Sin descripción" : proyecto.Description)
                                        </RadzenText>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat">Este participante aún no tiene proyectos públicos en su portafolio.</RadzenAlert>
                    }
                </RadzenCard>

            </RadzenColumn>
        </RadzenRow>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Participante? participante;
    private bool cargando = true;

    // Bandera para controlar la vista
    private bool modoEdicion = false;

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        cargando = true;
        participante = await ParticipanteService.ObtenerDashboardAsync(Id);
        cargando = false;
    }

    // --- MÉTODOS DE NAVEGACIÓN ---
    private async Task VolverAtras()
    {
        // ¡Magia de JavaScript! Esto es como darle a la flecha de "Atrás" del navegador
        await JSRuntime.InvokeVoidAsync("history.back");
    }

    // --- MÉTODOS DE EDICIÓN ---
    private void ActivarEdicion()
    {
        modoEdicion = true;
    }

    private async Task CancelarEdicion()
    {
        modoEdicion = false;
        // Recargamos los datos de la base de datos para descartar los cambios no guardados
        await CargarDatos();
    }

    private async Task GuardarPerfil()
    {
        if (participante != null)
        {
            // Llamamos al método que limpiamos antes en tu ParticipanteService
            await ParticipanteService.ActualizarFichaAsync(participante);
            modoEdicion = false;

            // Opcional: Aquí podrías mostrar un RadzenNotification de "Guardado con éxito"
        }
    }

    private string ObtenerIniciales(string nombre)
    {
        if (string.IsNullOrWhiteSpace(nombre)) return "?";
        return nombre.Substring(0, 1).ToUpper();
    }
}