@page "/"
@rendermode InteractiveServer

@using Votify.Core.Factories
@using Votify.Core.Models
@using Votify.Core.Interfaces
@using Votify.Services.Interfaces
@using Votify.Services.Models
@inject NavigationManager NavigationManager
@inject IEventoService EventoService
@inject IProyectoService ProyectoService
@inject IVotoPopularService VotoPopularService
@inject IVotoPuntuacionService VotoPuntuacionService

<PageTitle>Inicio - Votify</PageTitle>

@* ==========================================
   HERRAMIENTA DE DESARROLLO (MOCK LOGIN)
   ========================================== *@
<div class="alert alert-warning py-2 mb-4 d-flex align-items-center justify-content-between">
    <span class="fw-bold">🛠️ Modo Dev (Selector de Roles):</span>
    <select class="form-select w-auto" @bind="RolActual">
        <option value="Votante">Votante (Anónimo/Público)</option>
        <option value="Participante">Participante</option>
        <option value="Organizador">Organizador</option>
        <option value="Jurado">Jurado</option>
    </select>
</div>

@* ==========================================
   CONTENIDO DINÁMICO SEGÚN EL ROL
   ========================================== *@

@if (RolActual == "Votante")
{
    @if (RolActual == "Votante")
    {
        <div class="container d-flex flex-column align-items-center justify-content-center" style="min-height: 60vh;">
            <h2 class="mb-4">Accede como votante a una votación</h2>
            <div class="card shadow-sm p-4 text-center" style="max-width: 400px; width: 100%;">
                <label class="form-label mb-3">Introduce el código de la votación</label>
                <input type="number" class="form-control mb-3 text-center fs-4"
                       placeholder="Ej: 1"
                       @bind="codigoVotacion" />
                @if (!string.IsNullOrEmpty(mensajeErrorVotante))
                {
                    <div class="alert alert-danger small">@mensajeErrorVotante</div>
                }
                <button class="btn btn-primary w-100" @onclick="AccederVotacion">Continuar</button>
            </div>
        </div>
    }
}
else if (RolActual == "Participante")
{
    <div class="container mt-5" style="max-width: 600px;">
        <div class="card p-4 shadow-sm text-center">
            <h3 class="mb-3">Inscripción de Proyecto</h3>
            <p class="text-muted mb-4">Introduce el código del evento al que fuiste invitado.</p>

            @if (eventoEncontrado == null)
            {
                <input type="text" @bind="codigoBusqueda" placeholder="Ej: HACK26" class="form-control mb-3 fs-5 text-center text-uppercase mx-auto" style="max-width: 300px;" />
                <button class="btn btn-primary px-5" @onclick="BuscarEvento">Buscar Evento</button>

                @if (!string.IsNullOrEmpty(mensajeErrorParticipante))
                {
                    <div class="alert alert-danger mt-3">@mensajeErrorParticipante</div>
                }
                @if (!string.IsNullOrEmpty(mensajeExitoParticipante))
                {
                    <div class="alert alert-success mt-3">@mensajeExitoParticipante</div>
                }
            }
            else
            {
                <div class="alert alert-success d-flex align-items-center justify-content-center">
                    <strong>Evento Encontrado: @eventoEncontrado.Name</strong>
                </div>

                <div class="text-start mt-4">
                    <label class="fw-bold mb-1">Nombre de tu Proyecto *</label>
                    <input type="text" @bind="nombreProyecto" class="form-control mb-3" />

                    <label class="fw-bold mb-1">Especialidad del Proyecto *</label>
                    <select @bind="tipoProyectoSeleccionado" class="form-select mb-3">
                        @foreach (var opcion in opcionesTipoProyecto)
                        {
                            <option value="@opcion">@opcion</option>
                        }
                    </select>

                    <label class="fw-bold mb-1">Categoría en la que compites *</label>
                    <select @bind="categoriaSeleccionadaId" class="form-select mb-4">
                        <option value="0">Selecciona una categoría...</option>
                        @if (eventoEncontrado.CategoriasEvento != null)
                        {
                            @foreach (var cat in eventoEncontrado.CategoriasEvento)
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        }
                    </select>

                    <div class="d-flex justify-content-between">
                        <button class="btn btn-light" @onclick="() => eventoEncontrado = null">Cancelar</button>
                        <button class="btn btn-secondary" @onclick="InscribirProyecto">Inscribir Proyecto</button>
                    </div>
                </div>
            }
        </div>
    </div>
}
else if (RolActual == "Organizador")
{
    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Hola, @NombreUsuario</h2>
            <RadzenButton Text="+ Añadir Evento" Click="@(() => NavigationManager.NavigateTo("/eventos/crear"))" ButtonStyle="ButtonStyle.Primary" />
        </div>

        <h4 class="mb-3">Mis Eventos (@misEventos.Count())</h4>

        <div class="row">
            @foreach (var ev in misEventos)
            {
                <div class="col-md-6 mb-4">
                    <RadzenCard class="h-100 shadow-sm">
                        <div class="d-flex mb-3">
                            <div class="bg-primary text-white d-flex align-items-center justify-content-center rounded" style="width: 80px; height: 80px;">
                                <RadzenIcon Icon="event" Style="font-size: 3rem" />
                            </div>
                            <div class="ms-3">
                                <h5 class="mb-1">@ev.Name</h5>
                                <p class="text-muted mb-1 small">
                                    <RadzenIcon Icon="calendar_today" Style="font-size: 0.8rem" />
                                    @ev.FechaInicio.ToLocalTime().ToString("dd MMM") - @ev.FechaFin.ToLocalTime().ToString("dd MMM yyyy")
                                </p>
                                <div class="mt-2 mb-2 p-2 bg-light border rounded d-flex justify-content-between align-items-center">
                                    <span class="small fw-bold text-muted">Código de invitación:</span>
                                    <span class="badge bg-warning text-dark fs-6 font-monospace" style="letter-spacing: 2px;">@ev.CodigoAcceso</span>
                                </div>
                                <div class="mt-2">
                                    @foreach (var cat in ev.CategoriasEvento)
                                    {
                                        <span class="badge bg-light text-primary border me-1">@cat.Name</span>
                                    }
                                </div>
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <RadzenButton Text="Modificar" ButtonStyle="ButtonStyle.Light" class="w-100" 
                                          Click="@(() => NavigationManager.NavigateTo($"/eventos/editar/{ev.Id}"))" />
                            <RadzenButton Text="Publicar" ButtonStyle="ButtonStyle.Primary" class="w-100" />
                        </div>
                    </RadzenCard>
                </div>
            }
        </div>
    </div>
}
else if (RolActual == "Jurado")
{
    <div class="container mt-4">
        <h2 class="mb-4">Hola, Nombre de usuario</h2>

        <h4 class="mb-3">Mis Eventos a evaluar</h4>
        <div class="row">
            <div class="col-md-6 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex mb-3">
                            <div class="bg-secondary text-white d-flex align-items-center justify-content-center rounded" style="width: 80px; height: 80px;">Img</div>
                            <div class="ms-3">
                                <h5>Nombre del evento</h5>
                                <p class="text-muted mb-1 small">Fecha inicio - Fecha fin</p>
                                <p class="text-muted small">Lugar del evento</p>
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <button class="btn btn-outline-secondary w-100">Ver Proyectos y Participantes</button>
                            <button class="btn btn-primary w-100" disabled>Acceder a Votación (Cerrada)</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private string codigoVotacion = "";
    private string? mensajeErrorVotante;

    private async Task AccederVotacion()
    {
        mensajeErrorVotante = null;

        if (string.IsNullOrWhiteSpace(codigoVotacion))
        {
            mensajeErrorVotante = "Introduce un código de votación.";
            return;
        }

        if (!int.TryParse(codigoVotacion, out int id))
        {
            mensajeErrorVotante = "El código debe ser un número.";
            return;
        }

        try
        {
            await VotoPopularService.ObtenerDetallePorIdAsync(id);
            NavigationManager.NavigateTo($"/voto-popular-usuario/{id}");
            return;
        }
        catch { }

        try
        {
            await VotoPuntuacionService.ObtenerDetallePorIdAsync(id);
            NavigationManager.NavigateTo($"/voto-puntuacion-usuario/{id}");
            return;
        }
        catch { }

        mensajeErrorVotante = "No se encontró ninguna votación con ese código.";
    }
    private string _rolActual = "Votante";
    private string RolActual
    {
        get => _rolActual;
        set { _rolActual = value; OnRoleChanged(); }
    }

    private string NombreUsuario = "Invitado";
    private IEnumerable<Evento> misEventos = new List<Evento>();

    private string codigoBusqueda = "";
    private Evento? eventoEncontrado;
    private string? mensajeErrorParticipante;
    private string? mensajeExitoParticipante;

    private string nombreProyecto = "";
    private string? descripcionProyecto; // Opcional, depende de si lo pusiste en tu UI
    private int categoriaSeleccionadaId;
    // Añade esto junto a tus otras variables del participante
    private string tipoProyectoSeleccionado = "IA";
    private List<string> opcionesTipoProyecto = new List<string> { "IA", "Sostenibilidad", "Ciberseguridad" };

    protected override async Task OnInitializedAsync()
    {
        await CargarDatosSegunRol();
    }

    private async void OnRoleChanged()
    {
        eventoEncontrado = null;
        codigoBusqueda = "";
        nombreProyecto = "";
        descripcionProyecto = null;
        mensajeErrorParticipante = null;
        mensajeExitoParticipante = null;

        await CargarDatosSegunRol();
        StateHasChanged(); // Forzamos a Blazor a repintar
    }

    private async Task CargarDatosSegunRol()
    {
        if (RolActual == "Organizador")
        {
            NombreUsuario = "Alan Brito"; // El nombre que pusimos en el Seeder
            // Hardcodeamos el ID 1 que es el del primer organizador del Seeder
            int miOrgaId = await EventoService.ObtenerOrganizadorMockIdAsync();
            misEventos = await EventoService.ObtenerEventosPorOrganizadorAsync(miOrgaId);
        }
        else if (RolActual == "Participante")
        {
            misEventos = new List<Evento>();
            NombreUsuario = "Participante Demo"; // Para que el saludo de arriba cambie
        }
        else if (RolActual == "Jurado")
        {
            misEventos = new List<Evento>();
            NombreUsuario = "Jurado Demo";
        }
        else
        {
            misEventos = new List<Evento>();
            NombreUsuario = "Usuario Demo";
        }
    }

    private async Task BuscarEvento()
    {
        mensajeErrorParticipante = null;
        mensajeExitoParticipante = null;

        if (string.IsNullOrWhiteSpace(codigoBusqueda)) return;

        eventoEncontrado = await EventoService.ObtenerEventoPorCodigoAsync(codigoBusqueda);

        if (eventoEncontrado == null)
        {
            mensajeErrorParticipante = "No hemos encontrado ningún evento con ese código.";
        }
    }

    private async Task InscribirProyecto()
    {
        mensajeErrorParticipante = null;

        if (string.IsNullOrWhiteSpace(nombreProyecto) || categoriaSeleccionadaId == 0)
        {
            mensajeErrorParticipante = "El nombre del proyecto y la categoría son obligatorios.";
            return;
        }

        try
        {
            // 1. Mockeamos el ID del participante (suponiendo que en tu Seeder es el ID 3)
            // TODO: Cambiar esto cuando tu compañero acabe el Login (UT 3616)
            int participanteMockId = 3;

            // 2. Instanciamos tu Proyecto usando el constructor blindado
            ProyectoCreator creator;

            // 1. Elegimos la fábrica correcta según lo que seleccionó el usuario
            if (tipoProyectoSeleccionado == "IA")
            {
                creator = new AiProjectCreator();
            }
            else if (tipoProyectoSeleccionado == "Sostenibilidad")
            {
                creator = new SustainabilityProjectCreator();
            }
            else if (tipoProyectoSeleccionado == "Ciberseguridad")
            {
                creator = new CybersecurityProjectCreator();
            }
            else
            {
                creator = new AiProjectCreator(); // Fallback por seguridad
            }

            // 2. Usamos el método de la fábrica para instanciar el proyecto concreto
            // Fíjate que devolvemos un 'Proyecto' abstracto, ocultando la complejidad
            Proyecto nuevoProyecto = creator.CrearProyecto(nombreProyecto, participanteMockId);

            // (Si le añadiste la descripción al proyecto, la asignarías aquí si la necesitas)

            // 3. Lo guardamos a través del servicio
            await ProyectoService.CrearProyectoConCategoriaAsync(nuevoProyecto, categoriaSeleccionadaId);

            // 4. Limpiamos la UI y mostramos el éxito
            mensajeExitoParticipante = $"¡Tu proyecto '{nombreProyecto}' fue inscrito exitosamente!";
            eventoEncontrado = null;
            codigoBusqueda = "";
            nombreProyecto = "";
            descripcionProyecto = null;
            categoriaSeleccionadaId = 0;
        }
        catch (Exception ex)
        {
            mensajeErrorParticipante = $"Error al inscribir: {ex.Message}";
        }
    }
}
