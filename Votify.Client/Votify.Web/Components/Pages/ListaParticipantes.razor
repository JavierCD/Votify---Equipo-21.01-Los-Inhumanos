@page "/participantes"
@rendermode InteractiveServer

@using Votify.Core.Models
@using Votify.Core.Interfaces
@inject IParticipanteService ParticipanteService
@inject NavigationManager NavManager

<PageTitle>Participantes - Votify</PageTitle>

<div class="container rz-mt-4">
    <RadzenText TextStyle="TextStyle.H3">Lista de Participantes</RadzenText>

    @if (participantes == null)
    {
        <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
    }
    else
    {
        @* Aquí usamos la tabla mágica de Radzen *@
        <RadzenDataGrid Data="@participantes" TItem="Participante" AllowPaging="true" PageSize="10" AllowSorting="true" class="rz-mt-4 rz-shadow-3">
            <Columns>
                <RadzenDataGridColumn TItem="Participante" Property="Id" Title="ID" Width="70px" TextAlign="TextAlign.Center" />
                <RadzenDataGridColumn TItem="Participante" Property="Name" Title="Nombre" />
                <RadzenDataGridColumn TItem="Participante" Property="Email" Title="Email" />

                @* Columna personalizada para mostrar la etiqueta de colores *@
                <RadzenDataGridColumn TItem="Participante" Property="Estado" Title="Estado" Width="120px">
                    <Template Context="p">
                        <RadzenBadge BadgeStyle="ObtenerColorEstado(p.Estado)" Text="@p.Estado" IsPill="true" />
                    </Template>
                </RadzenDataGridColumn>

                @* Columna con el botón para ir a la Ficha *@
                <RadzenDataGridColumn TItem="Participante" Title="Ficha" Width="80px" TextAlign="TextAlign.Center">
                    <Template Context="p">
                        <RadzenButton Icon="person_search" ButtonStyle="ButtonStyle.Info" Size="ButtonSize.Small" Click="@(() => VerFicha(p.Id))" />
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    }
</div>

@code {
    private IEnumerable<Participante>? participantes;

    protected override async Task OnInitializedAsync()
    {
        // Traemos todos los participantes de la base de datos
        participantes = await ParticipanteService.ObtenerTodosAsync();
    }

    private void VerFicha(int id)
    {
        // Esto hace que el navegador viaje a la URL de la ficha de ese participante
        NavManager.NavigateTo($"/ficha-participante/{id}");
    }

    private BadgeStyle ObtenerColorEstado(string estado)
    {
        return estado switch
        {
            "Aprobado" => BadgeStyle.Success,
            "Rechazado" => BadgeStyle.Danger,
            _ => BadgeStyle.Warning
        };
    }
}