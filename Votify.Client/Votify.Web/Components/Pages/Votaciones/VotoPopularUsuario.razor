@page "/voto-popular-usuario/{VotacionId:int}"
@rendermode InteractiveServer
@using Votify.Core.Models                        
@using Votify.Services.Interfaces
@using Votify.Services.Models
@using Votify.Web.Services                      
@inject IPopularService PopularService          
@inject UserSession Session                      
@inject ILogger<VotoPopularUsuario> Logger
@inject IVotoPopularService VotoPopularService

<div class="container py-4" style="max-width:680px">

    <div class="mb-4">
        <h2 class="fw-bold mb-1">Votación Popular</h2>
        <p class="text-muted small mb-0">Participa votando por tus proyectos favoritos.</p>
    </div>

    @if (cargando)
    {
        <div class="d-flex align-items-center gap-2 text-muted">
            <span class="spinner-border spinner-border-sm"></span>
            <span>Cargando...</span>
        </div>
    }
    else if (votacionSeleccionada is null)
    {
        @* ── COMPAÑEROS: lista de votaciones ── *@

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="alert alert-danger rounded-3">@errorMessage</div>
        }

        @if (!listaVotaciones.Any())
        {
            <div class="alert alert-warning rounded-3">No hay votaciones populares disponibles en este momento.</div>
        }
        else
        {
            <p class="text-muted mb-3">Selecciona una categoría para votar:</p>

            @foreach (var v in listaVotaciones)
            {
                var idLocal = v.VotacionId;
                <div class="card border-0 shadow-sm rounded-4 mb-3 p-3">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h5 class="fw-bold mb-1">@v.CategoriaNombre</h5>
                            <span class="badge bg-success-subtle text-success me-2">@v.Estado</span>
                            <span class="badge bg-primary-subtle text-primary">Máx. @v.MaxSelection selección(es)</span>
                        </div>
                        <button type="button" class="btn btn-primary px-4" @onclick="() => SeleccionarVotacion(idLocal)">
                            Participar →
                        </button>
                    </div>
                </div>
            }
        }
    }
    else
    {
        @* ── COMPAÑEROS: detalle con proyectos y formulario ── *@

        <div class="card border-0 shadow-sm rounded-4 p-3 mb-4">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="fw-bold mb-1">@votacionSeleccionada.CategoriaNombre</h4>
                    <span class="badge bg-success-subtle text-success me-2">@votacionSeleccionada.Estado</span>
                    <span class="badge bg-primary-subtle text-primary">Máx. @votacionSeleccionada.MaxSelection selección(es)</span>
                </div>
                <div class="text-end">
                    <span class="fs-4 fw-bold text-primary">@proyectosSeleccionados.Count</span>
                    <span class="text-muted small"> / @votacionSeleccionada.MaxSelection</span>
                </div>
            </div>
        </div>

        @* ← NUEVO: aviso informativo cuando la restricción de autovoto está activa y el usuario es Participante *@
        @if (!votacionSeleccionada.PermiteAutoVoto && Session.Usuario is Participante)
        {
            <div class="alert alert-info rounded-3 small">
                En esta votación no puedes votar tus propios proyectos.
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="alert alert-danger rounded-3 d-flex align-items-center gap-2">
                <span>✕</span><span>@errorMessage</span>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(successMessage))
        {
            <div class="alert alert-success rounded-3 d-flex align-items-center gap-2">
                <span>✓</span><span>@successMessage</span>
            </div>
        }

        @if (string.IsNullOrWhiteSpace(successMessage))
        {
            @* ── NUEVA UT: PASO 1 - IDENTIFICACIÓN (Solo pedir correo) ── *@
            @if (!identificado)
            {
                <div class="card border-0 shadow-sm rounded-4 p-4">
                    <h5 class="fw-bold mb-3">Identificación</h5>
                    <p class="text-muted small mb-4">
                        Introduce tu email. Lo utilizaremos exclusivamente para enviarte los resultados finales y tu certificado de participación cuando el evento termine.
                    </p>

                    <div class="mb-4">
                        <label class="form-label fw-semibold small text-uppercase text-muted">Correo Electrónico</label>
                        <input type="email" class="form-control form-control-lg" @bind="emailVotante" placeholder="ejemplo@correo.com" />
                    </div>

                    <button type="button" class="btn btn-primary w-100 py-2 fw-bold" @onclick="ContinuarAVotar" disabled="@string.IsNullOrWhiteSpace(emailVotante)">
                        Continuar a la Votación
                    </button>

                    @if (!string.IsNullOrEmpty(errorEmail))
                    {
                        <div class="alert alert-danger mt-3 small py-2">@errorEmail</div>
                    }
                </div>
            }
            else
            {
                @* ── COMPAÑEROS: PASO 2 - EL FORMULARIO ORIGINAL INTACTO ── *@
                <div class="card border-0 shadow-sm rounded-4 p-4">

                    <div class="alert alert-info py-2 small mb-4 d-flex justify-content-between align-items-center">
                        <span>Votando para recibir resultados en: <strong>@emailVotante</strong></span>
                        <button type="button" class="btn btn-link btn-sm p-0 text-decoration-none" @onclick="() => identificado = false">Cambiar</button>
                    </div>

                    <EditForm Model="@formModel" OnValidSubmit="@EmitirVotoAsync">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="text-danger small" />


                   

                        <div class="mb-4">
                            <label class="form-label fw-semibold small text-uppercase text-muted">Selecciona los proyectos</label>
                            @foreach (var proyecto in votacionSeleccionada.Proyectos)
                            {
                                var proyectoIdLocal = proyecto.Id;
                                var proyectoNombre = proyecto.Name;
                                var seleccionado = proyectosSeleccionados.Contains(proyectoIdLocal);

                                <div class="card mb-2 border rounded-3 p-3 @(seleccionado ? "border-primary bg-primary bg-opacity-10" : "bg-light")"
                                     style="cursor:pointer"
                                     @onclick="() => AlternarProyecto(proyectoIdLocal, !seleccionado)">
                                    <div class="d-flex align-items-center gap-3">
                                        <input type="checkbox"
                                               class="form-check-input mt-0"
                                               id="proy-@proyectoIdLocal"
                                               checked="@seleccionado"
                                               @onchange="(e => AlternarProyecto(proyectoIdLocal, e.Value is bool m && m))"
                                               @onclick:stopPropagation="true" />
                                        <label class="form-check-label fw-semibold mb-0" for="proy-@proyectoIdLocal" style="cursor:pointer">
                                            @proyectoNombre
                                        </label>
                                        @if (seleccionado)
                                        {
                                            <span class="badge bg-primary ms-auto">Seleccionado</span>
                                        }
                                    </div>
                                </div>
                            }
                        </div>

                        <hr class="my-3" />

                        <button type="submit" class="btn btn-primary w-100 py-2 fw-bold" disabled="@enviando">
                            @if (enviando)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                <span>Enviando...</span>
                            }
                            else
                            {
                                <span>Enviar voto</span>
                            }
                        </button>
                    </EditForm>
                </div>
            }
        }
    }
</div>

@code {
    [Parameter]
    public int VotacionId { get; set; }

    // --- VARIABLES DE LA NUEVA UT ---
    private string emailVotante = "";
    private bool identificado = false;
    private string errorEmail = "";

    // --- VARIABLES ORIGINALES DE TUS COMPAÑEROS ---
    private List<VotacionPopularDisponibleResponse> listaVotaciones = new();
    private VotacionPopularDisponibleResponse? votacionSeleccionada;
    private FormVotoPopularModel formModel = new();
    private List<int> proyectosSeleccionados = new();

    private bool cargando = true;
    private bool enviando = false;
    private string? errorMessage;
    private string? successMessage;
    private VotacionPopularDisponibleResponse? votacion;

    protected override async Task OnInitializedAsync()
    {
        // ← CAMBIO: sesión inyectada correctamente (antes: SessionExtensions.Usuario, que no existe)
        int votanteId = Session.Usuario is Participante p ? p.Id : 0;

        try
        {
            listaVotaciones = await VotoPopularService.ObtenerVotacionesDisponiblesAsync(votanteId);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            Logger.LogError(ex, "Error cargando votaciones populares.");
        }
        try
        {
            // ← CAMBIO: llamamos al método de la UT 3271 que filtra los proyectos del propio participante
            votacionSeleccionada = await PopularService.ObtenerProyectosParaVotarAsync(VotacionId, votanteId);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            Logger.LogError(ex, "Error cargando votación popular.");
        }
        finally
        {
            cargando = false;
        }
    }

    // --- MÉTODO DE LA NUEVA UT ---
    private void ContinuarAVotar()
    {
        if (!System.Text.RegularExpressions.Regex.IsMatch(emailVotante, @"^[^@\s]+@[^@\s]+\.[^@\s]+$"))
        {
            errorEmail = "Por favor, introduce un correo electrónico con formato válido.";
            return;
        }

        identificado = true;
        errorEmail = "";
    }

    // --- MÉTODOS ORIGINALES INTACTOS ---
    private async Task SeleccionarVotacion(int votacionId)
    {
        errorMessage = null;
        successMessage = null;

        try
        {
            // ← CAMBIO: al seleccionar de la lista, también filtramos por autovoto
            int votanteId = Session.Usuario is Participante p ? p.Id : 0;
            votacionSeleccionada = await PopularService.ObtenerProyectosParaVotarAsync(votacionId, votanteId);

            proyectosSeleccionados.Clear();
            formModel = new FormVotoPopularModel();
            identificado = false; // Reseteamos la UT si cambian de votación
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            Logger.LogError(ex, "Error cargando detalle de votación.");
        }
    }

    private void Volver()
    {
        votacionSeleccionada = null;
        proyectosSeleccionados.Clear();
        errorMessage = null;
        successMessage = null;
        formModel = new FormVotoPopularModel();
        identificado = false;
    }

    private void AlternarProyecto(int proyectoId, bool seleccionado)
    {
        if (votacionSeleccionada is null) return;
        errorMessage = null;

        if (seleccionado)
        {
            if (proyectosSeleccionados.Contains(proyectoId)) return;

            if (proyectosSeleccionados.Count >= votacionSeleccionada.MaxSelection)
            {
                errorMessage = $"Solo puedes seleccionar hasta {votacionSeleccionada.MaxSelection} proyecto(s).";
                return;
            }

            proyectosSeleccionados.Add(proyectoId);
        }
        else
        {
            proyectosSeleccionados.Remove(proyectoId);
        }
    }

    private async Task EmitirVotoAsync()
    {
        if (votacionSeleccionada is null)
        {
            errorMessage = "No hay votación cargada.";
            return;
        }

        errorMessage = null;
        successMessage = null;
        enviando = true;

        try
        {

            var request = new EmitirVotoPopularRequest
            {
                VotacionId = votacionSeleccionada.VotacionId,
                VotanteId = 0,
                Anonimo = true,
                ProyectosSeleccionadosIds = proyectosSeleccionados.ToList(),
                Email = emailVotante
            };

            await VotoPopularService.EmitirVotoPopularAsync(request);

            successMessage = "¡Voto emitido correctamente! Pronto recibirás los resultados en tu correo.";
            proyectosSeleccionados.Clear();
            formModel = new FormVotoPopularModel();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            Logger.LogError(ex, "Error emitiendo voto popular.");
        }
        finally
        {
            enviando = false;
        }
    }

    public class FormVotoPopularModel
    {
        public int VotanteId { get; set; } = 0;
        public bool Anonimo { get; set; } = true;
    }
}