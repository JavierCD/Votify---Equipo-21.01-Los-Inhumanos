@page "/voto-puntuacion-usuario/{VotacionId:int}"
@rendermode InteractiveServer
@using Votify.Core.Models
@using Votify.Services.Interfaces
@using Votify.Services.Models
@using Votify.Web.Services
@inject IVotoPuntuacionService VotoPuntuacionService
@inject IPuntuacionService PuntuacionService
@inject UserSession Session
@inject ILogger<VotoPuntuacionUsuario> Logger

<div class="container py-4" style="max-width:680px">

    <div class="mb-4">
        <h2 class="fw-bold mb-1">Votación por Puntuación</h2>
        <p class="text-muted small mb-0">Asigna una puntuación a cada proyecto.</p>
    </div>

    @if (cargando)
    {
        <div class="d-flex align-items-center gap-2 text-muted">
            <span class="spinner-border spinner-border-sm"></span>
            <span>Cargando...</span>
        </div>
    }
    else if (votacion is null)
    {
        <div class="alert alert-danger rounded-3">@errorMessage</div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-4 p-3 mb-4">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="fw-bold mb-1">@votacion.CategoriaNombre</h4>
                    <span class="badge bg-success-subtle text-success me-2">@votacion.Estado</span>
                    <span class="badge bg-primary-subtle text-primary">Máx. @votacion.ValorMax puntos por proyecto</span>
                </div>
            </div>
        </div>

        @* ← UT 3271: aviso cuando la restricción de autovoto está activa y el usuario es Participante *@
        @if (!votacion.PermiteAutoVoto && Session.Usuario is Participante)
        {
            <div class="alert alert-info rounded-3 small">
                En esta votación no puedes votar tus propios proyectos.
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="alert alert-danger rounded-3 d-flex align-items-center gap-2">
                <span>✕</span><span>@errorMessage</span>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(successMessage))
        {
            <div class="alert alert-success rounded-3 d-flex align-items-center gap-2">
                <span>✓</span><span>@successMessage</span>
            </div>
        }

        @if (string.IsNullOrWhiteSpace(successMessage))
        {
            @* ── PASO 1: PANTALLA DE IDENTIFICACIÓN ── *@
            @if (!identificado)
            {
                <div class="card border-0 shadow-sm rounded-4 p-4">
                    <h5 class="fw-bold mb-3">Identificación</h5>
                    <p class="text-muted small mb-4">
                        Introduce tu email. Lo utilizaremos exclusivamente para enviarte los resultados finales y tu certificado de participación cuando el evento termine.
                    </p>

                    <div class="mb-4">
                        <label class="form-label fw-semibold small text-uppercase text-muted">Correo Electrónico</label>
                        <input type="email" class="form-control form-control-lg" @bind="emailVotante" placeholder="ejemplo@correo.com" />
                    </div>

                    <button type="button" class="btn btn-primary w-100 py-2 fw-bold" @onclick="ContinuarAVotar" disabled="@string.IsNullOrWhiteSpace(emailVotante)">
                        Continuar a la Votación
                    </button>

                    @if (!string.IsNullOrEmpty(errorEmail))
                    {
                        <div class="alert alert-danger mt-3 small py-2">@errorEmail</div>
                    }
                </div>
            }
            else
            {
                @* ── PASO 2: FORMULARIO DE VOTACIÓN ── *@
                <div class="card border-0 shadow-sm rounded-4 p-4">

                    <div class="alert alert-info py-2 small mb-4 d-flex justify-content-between align-items-center">
                        <span>Votando para recibir resultados en: <strong>@emailVotante</strong></span>
                        <button type="button" class="btn btn-link btn-sm p-0 text-decoration-none" @onclick="() => identificado = false">Cambiar</button>
                    </div>

                    <EditForm Model="@formModel" OnValidSubmit="@EmitirVotoAsync">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="text-danger small" />

                        <div class="mb-4">
                            <label class="form-label fw-semibold small text-uppercase text-muted">Puntúa los proyectos</label>
                            @foreach (var proyecto in votacion.Proyectos)
                            {
                                <div class="card mb-2 border rounded-3 p-3 bg-light">
                                    <div class="d-flex align-items-center justify-content-between gap-3">
                                        <span class="fw-semibold">@proyecto.Name</span>
                                        <input type="number"
                                               class="form-control fw-bold text-center"
                                               style="max-width: 100px;"
                                               min="0"
                                               max="@votacion.ValorMax"
                                               value="@ObtenerPuntuacion(proyecto.Id)"
                                               @onchange="e => ActualizarPuntuacion(proyecto.Id, e.Value?.ToString())" />
                                    </div>
                                </div>
                            }
                        </div>

                        <hr class="my-3" />

                        <button type="submit" class="btn btn-primary w-100 py-2 fw-bold" disabled="@enviando">
                            @if (enviando)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                <span>Enviando...</span>
                            }
                            else
                            {
                                <span>Enviar voto</span>
                            }
                        </button>
                    </EditForm>
                </div>
            }
        }
    }
</div>

@code {
    [Parameter]
    public int VotacionId { get; set; }

    // --- VARIABLES DE IDENTIFICACIÓN ---
    private string emailVotante = "";
    private bool identificado = false;
    private string errorEmail = "";

    // --- VARIABLES ORIGINALES ---
    private VotacionPuntuacionDetalleResponse? votacion;
    private FormVotoPuntuacionModel formModel = new();
    private Dictionary<int, int> puntuaciones = new();

    private bool cargando = true;
    private bool enviando = false;
    private string? errorMessage;
    private string? successMessage;

    protected override async Task OnInitializedAsync()
    {
        // ← UT 3271: calcular votanteId para filtrar proyectos propios
        int votanteId = Session.Usuario is Participante p ? p.Id : 0;

        try
        {
            // ← UT 3271: usar ObtenerProyectosParaVotarAsync en vez de ObtenerDetallePorIdAsync
            // para que el filtro de autovoto aplique
            votacion = await PuntuacionService.ObtenerProyectosParaVotarAsync(VotacionId, votanteId);

            if (votacion != null)
            {
                foreach (var pr in votacion.Proyectos)
                    puntuaciones[pr.Id] = 0;
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            Logger.LogError(ex, "Error cargando votación por puntuación.");
        }
        finally
        {
            cargando = false;
        }
    }

    // --- MÉTODO DE VALIDACIÓN DE CORREO ---
    private void ContinuarAVotar()
    {
        if (!System.Text.RegularExpressions.Regex.IsMatch(emailVotante, @"^[^@\s]+@[^@\s]+\.[^@\s]+$"))
        {
            errorEmail = "Por favor, introduce un correo electrónico con formato válido.";
            return;
        }

        identificado = true;
        errorEmail = "";
    }

    // --- MÉTODOS ORIGINALES DE PUNTUACIÓN ---
    private int ObtenerPuntuacion(int proyectoId)
    {
        return puntuaciones.TryGetValue(proyectoId, out var val) ? val : 0;
    }

    private void ActualizarPuntuacion(int proyectoId, string? valor)
    {
        if (int.TryParse(valor, out var num))
        {
            if (votacion != null && num > votacion.ValorMax) num = votacion.ValorMax;
            if (num < 0) num = 0;

            puntuaciones[proyectoId] = num;
        }
    }

    private async Task EmitirVotoAsync()
    {
        errorMessage = null;
        successMessage = null;
        enviando = true;

        try
        {
            var request = new EmitirVotoPuntuacionRequest
            {
                VotacionId = VotacionId,
                VotanteId = 0,
                Anonimo = true,
                PuntuacionesPorProyecto = puntuaciones,
                Email = emailVotante
            };

            await VotoPuntuacionService.EmitirVotoPuntuacionAsync(request);

            successMessage = "¡Voto emitido correctamente! Pronto recibirás los resultados en tu correo.";

            foreach (var key in puntuaciones.Keys.ToList())
                puntuaciones[key] = 0;

            formModel = new FormVotoPuntuacionModel();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            Logger.LogError(ex, "Error emitiendo voto por puntuación.");
        }
        finally
        {
            enviando = false;
        }
    }

    public class FormVotoPuntuacionModel
    {
        public int VotanteId { get; set; } = 0;
        public bool Anonimo { get; set; } = true;
    }
}
