@page "/voto-popular"
@using Votify.Services.Interfaces
@using Votify.Services.Models
@inject IPopularService PopularService
@inject ILogger<VotoPopular> Logger

<h3>Crear votación popular</h3>

<EditForm Model="@request" OnValidSubmit="CrearVotacionPopularAsync" FormName="crearVotacionPopularForm">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label class="form-label">ID de la categoría</label>
        <InputNumber @bind-Value="request.CategoriaId" class="form-control" />
        <ValidationMessage For="@(() => request.CategoriaId)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Fecha de apertura</label>
        <InputDate @bind-Value="request.FechaApertura" class="form-control" />
        <ValidationMessage For="@(() => request.FechaApertura)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Fecha de cierre</label>
        <InputDate @bind-Value="request.FechaCierre" class="form-control" />
        <ValidationMessage For="@(() => request.FechaCierre)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Estado</label>
        <InputText @bind-Value="request.Estado" class="form-control" />
        <ValidationMessage For="@(() => request.Estado)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Máximo de selecciones</label>
        <InputNumber @bind-Value="request.MaxSelection" class="form-control" />
        <ValidationMessage For="@(() => request.MaxSelection)" />
    </div>

    <button type="submit" class="btn btn-primary" disabled="@isLoading">
        @(isLoading ? "Guardando..." : "Crear votación")
    </button>
</EditForm>

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success mt-3">
        @successMessage
    </div>
}

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger mt-3">
        @errorMessage
    </div>
}

@code {
    private CrearVotacionPopularRequest request = new()
    {
        CategoriaId=1,
        FechaApertura = DateTime.Today,
        FechaCierre = DateTime.Today.AddDays(1),
        Estado = "Abierta",
        MaxSelection = 1
    };

    private bool isLoading = false;
    private string? successMessage;
    private string? errorMessage;

    private async Task CrearVotacionPopularAsync()
    {
        isLoading = true;
        successMessage = null;
        errorMessage = null;

        try
        {
            var response = await PopularService.CrearVotacionPopularAsync(request);

            successMessage = $"Votación popular creada correctamente con ID {response.Id}.";
            LimpiarFormulario();
        }
        catch (ArgumentException ex)
        {
            errorMessage = ex.Message;
            Logger.LogWarning(ex, "Error de validación al crear votación popular.");
        }
        catch (InvalidOperationException ex)
        {
            errorMessage = ex.Message;
            Logger.LogWarning(ex, "Error de operación al crear votación popular.");
        }
        catch (Exception ex)
        {
            errorMessage = ex.InnerException is not null
                ? $"Error inesperado: {ex.Message} | Detalle: {ex.InnerException.Message}"
                : $"Error inesperado: {ex.Message}";

            Logger.LogError(ex, "Error inesperado al crear votación popular.");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void LimpiarFormulario()
    {
        request = new CrearVotacionPopularRequest
        {
            FechaApertura = DateTime.Today,
            FechaCierre = DateTime.Today.AddDays(1),
            Estado = "Abierta",
            MaxSelection = 1
        };
    }
}